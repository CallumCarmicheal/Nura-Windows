<UserControl x:Class="NuraPopupWpf.Controls.DevicePageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:NuraPopupWpf.Controls"
             mc:Ignorable="d">
    <UserControl.Resources>
        <DataTemplate x:Key="CompactDeviceTemplate">
            <controls:CompactDevicePageControl />
        </DataTemplate>
        <DataTemplate x:Key="ExpandedDeviceTemplate">
            <controls:ExpandedDevicePageControl />
        </DataTemplate>
    </UserControl.Resources>
    <ContentControl Margin="0,16"
                    Content="{Binding}">
        <ContentControl.Style>
            <Style TargetType="ContentControl">
                <Setter Property="ContentTemplate" Value="{StaticResource CompactDeviceTemplate}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                        <Setter Property="ContentTemplate" Value="{StaticResource ExpandedDeviceTemplate}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ContentControl.Style>
    </ContentControl>
</UserControl>
