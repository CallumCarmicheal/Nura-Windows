<UserControl x:Class="NuraPopupWpf.Controls.ExpandedSettingsPageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:NuraPopupWpf.Models"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.78*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Text="YOUR ACCOUNT" Style="{StaticResource SectionTitleStyle}" />
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,12,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Name" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding AccountNameDisplay}" Foreground="White" FontSize="13" HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>
                </Border>
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Email address" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding AccountEmailDisplay}" Foreground="White" FontSize="13" HorizontalAlignment="Right" VerticalAlignment="Center" TextWrapping="Wrap" />
                    </Grid>
                </Border>
                <Button Margin="0,0,0,16"
                        Command="{Binding LogoutAuthenticationCommand}"
                        Style="{StaticResource ValuePillButtonStyle}"
                        HorizontalAlignment="Stretch"
                        Visibility="{Binding HasAuthenticatedWithNura, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock FontFamily="Segoe Fluent Icons"
                                   Text="&#xE8AC;"
                                   Foreground="#FFD18B9A"
                                   FontSize="13"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Log out"
                                   Foreground="White"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Margin="0,0,0,16"
                        Command="{Binding ReopenAuthenticationCommand}"
                        HorizontalAlignment="Stretch">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ValuePillButtonStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasAuthenticatedWithNura}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock FontFamily="Segoe Fluent Icons"
                                   Text="&#xE721;"
                                   Foreground="#FFB78CFF"
                                   FontSize="13"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Log in to Nura"
                                   Foreground="White"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <TextBlock Text="APP" Style="{StaticResource SectionTitleStyle}" />
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Desktop app version" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="0.9.0" Foreground="White" FontSize="13" HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>
                </Border>
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,10,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Use bitmap renderer" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                            <TextBlock Text="{Binding ProfileRendererSubtitle}" Foreground="White" FontSize="13" TextWrapping="Wrap" 
                                       d:Text="..." />
                        </StackPanel>
                        <ToggleButton Grid.Column="1"
                                      IsChecked="{Binding UseBitmapProfileRenderer, Mode=TwoWay}"
                                      Style="{StaticResource SwitchToggleButtonStyle}" />
                    </Grid>
                </Border>
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,10,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Connect to Nura" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                            <TextBlock Text="{Binding ConnectToNuraSubtitle}" Foreground="White" FontSize="13" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleButton Grid.Column="1"
                                      IsChecked="{Binding ConnectToNura, Mode=TwoWay}"
                                      Style="{StaticResource SwitchToggleButtonStyle}" />
                    </Grid>
                </Border>
                <TextBlock Text="USER INTERFACE" Style="{StaticResource SectionTitleStyle}" Margin="0,16,0,0" />
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="Band layout" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                        <Slider Margin="0,4,0,0"
                                Minimum="0"
                                Maximum="2"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Value="{Binding ProfileBandLayoutIndex, Mode=TwoWay}"
                                Style="{StaticResource ThreeStateSliderStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Circular"
                                       Grid.Column="0"
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       FontSize="11"
                                       HorizontalAlignment="Left" />
                            <TextBlock Text="Both"
                                       Grid.Column="1"
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       FontSize="11"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Pill"
                                       Grid.Column="2"
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       FontSize="11"
                                       HorizontalAlignment="Right" />
                        </Grid>
                        <TextBlock Margin="0,8,0,0" Text="{Binding ProfileBandLayoutSubtitle}" Foreground="White" FontSize="13" TextWrapping="Wrap" 
                                   MinHeight="35" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,10,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Show profile background haze" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                            <TextBlock Text="Expanded view only. Restore the large blurred purple haze behind the profile canvas." Foreground="White" FontSize="13" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleButton Grid.Column="1"
                                      IsChecked="{Binding ShowProfileBackgroundHaze, Mode=TwoWay}"
                                      Style="{StaticResource SwitchToggleButtonStyle}" />
                    </Grid>
                </Border>
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="Anchor" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                        <TextBlock Text="{Binding WindowAnchorSubtitle}" Foreground="White" FontSize="13" TextWrapping="Wrap" Margin="0,2,0,0" />
                        <ListBox Margin="0,10,0,0"
                                 ItemsSource="{Binding WindowAnchorOptions}"
                                 SelectedItem="{Binding SelectedWindowAnchorOption, Mode=TwoWay}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                 ItemContainerStyle="{StaticResource PillListBoxItemStyle}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Label}" Foreground="White" FontWeight="SemiBold" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,10,0,0">
                    <StackPanel>
                        <Button Command="{Binding ExportHearingProfilesCommand}"
                                Style="{StaticResource ValuePillButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Padding="12,10">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock FontFamily="Segoe Fluent Icons"
                                           FontWeight="Thin"
                                           Text="&#xE72D;"
                                           Foreground="#8AFF57B9"
                                           FontSize="20"
                                           Margin="0,0,8,0" 
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Export Hearing Profiles"
                                           Foreground="White"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <TextBlock Text="{Binding ExportStatusText}"
                                   Margin="0,10,0,0"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="#22FFFFFF" Width="4" Margin="0,8" CornerRadius="4"></Border>

                    <Border Grid.Column="1" Style="{StaticResource InfoChipBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="92" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Render size" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                                <TextBlock Text="PNG size in pixels. Min 4, max 12288." Foreground="White" FontSize="13" TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Grid.Column="1"
                Background="#10FFFFFF"
                BorderBrush="#22FFFFFF"
                BorderThickness="1"
                CornerRadius="24"
                SnapsToDevicePixels="True"
                Margin="20,0,0,0">
                                <TextBox Text="{Binding ExportRenderSizeText, UpdateSourceTrigger=PropertyChanged}" d:Text="12288"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="White"
                     Padding="16,8"
                     TextAlignment="Center"
                     VerticalContentAlignment="Center"
                     PreviewTextInput="NumberOnly_PreviewTextInput"
                     DataObject.Pasting="NumberOnly_Pasting" />
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Text="DEVICE SETTINGS" Style="{StaticResource SectionTitleStyle}" />
                <ListBox x:Name="DeviceListBox"
                         Margin="0,12,0,16"
                         ItemsSource="{Binding VisibleDevices}"
                         SelectedItem="{Binding CurrentDevice, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.Resources>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource PillListBoxItemStyle}">
                            <Setter Property="Margin" Value="0,0,0,8" />
                        </Style>
                    </ListBox.Resources>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:DeviceModel}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#55FFFFFF" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                    <Setter Property="Fill" Value="#FF64FFB0" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="White"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding WarningText}"
                                               Foreground="#FFFFB25F"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Margin="0,4,0,0"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasWarningText}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="12,0,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock FontFamily="Segoe Fluent Icons"
                                               Text="&#xE850;"
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0" />
                                    <TextBlock Text="{Binding BatteryLevel, StringFormat={}{0}%}"
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                    <Setter Property="Opacity" Value="0.5" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <ToggleButton x:Name="MoreDevicesButton"
                              Margin="0,0,0,16"
                              Background="#10FFFFFF"
                              BorderBrush="#22FFFFFF"
                              BorderThickness="1"
                              Foreground="White"
                              Padding="12,8"
                              HorizontalAlignment="Stretch"
                              Visibility="{Binding HasOverflowDevices, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="Chrome"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}"
                                    CornerRadius="16">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Chrome" Property="Background" Value="#16FFFFFF" />
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Chrome" Property="Background" Value="#18FFFFFF" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding MoreDevicesButtonText}" />
                        <TextBlock FontFamily="Segoe Fluent Icons"
                                   Text="&#xE70D;"
                                   Margin="8,0,0,0"
                                   Foreground="{StaticResource SubtleTextBrush}" />
                    </StackPanel>
                </ToggleButton>
                <Popup x:Name="MoreDevicesPopup"
                       IsOpen="{Binding IsChecked, ElementName=MoreDevicesButton}"
                       Closed="MoreDevicesPopup_OnClosed"
                       AllowsTransparency="True"
                       Placement="Bottom"
                       PlacementTarget="{Binding ElementName=MoreDevicesButton}"
                       VerticalOffset="8"
                       PopupAnimation="Fade"
                       StaysOpen="False">
                    <Border Width="{Binding ActualWidth, ElementName=MoreDevicesButton}"
                            Background="#F2121212"
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1"
                            CornerRadius="20"
                            Padding="6">
                        <ListBox ItemsSource="{Binding OverflowDevices}"
                                 SelectedItem="{Binding CurrentDevice, Mode=TwoWay}"
                                 BorderThickness="0"
                                 Background="Transparent">
                            <ListBox.Resources>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource PillListBoxItemStyle}">
                                    <Setter Property="Margin" Value="0,0,0,8" />
                                </Style>
                            </ListBox.Resources>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:DeviceModel}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#55FFFFFF" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                            <Setter Property="Fill" Value="#FF64FFB0" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="White"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding WarningText}"
                                                       Foreground="#FFFFB25F"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Margin="0,4,0,0"
                                                       TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasWarningText}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Margin="12,0,0,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock FontFamily="Segoe Fluent Icons"
                                                       Text="&#xE850;"
                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,6,0" />
                                            <TextBlock Text="{Binding BatteryLevel, StringFormat={}{0}%}"
                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Popup>

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Opacity" Value="1" />
                            <Setter Property="IsEnabled" Value="True" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CanInteractWithCurrentDeviceControls}" Value="False">
                                    <Setter Property="Opacity" Value="0.4" />
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="ANC" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                            <TextBlock Text="{Binding CurrentDevice.AncStatusText}" Foreground="White" FontSize="13" d:Text="..." />
                        </StackPanel>
                        <ToggleButton Grid.Column="1"
                                      IsChecked="{Binding CurrentDevice.AncEnabled, Mode=TwoWay}"
                                      Style="{StaticResource SwitchToggleButtonStyle}" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Enable EU volume limiter" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                            <TextBlock Text="Protect output levels" Foreground="White" FontSize="13" />
                        </StackPanel>
                        <ToggleButton Grid.Column="1"
                                      IsChecked="{Binding CurrentDevice.EuVolumeLimiter, Mode=TwoWay}"
                                      Style="{StaticResource SwitchToggleButtonStyle}" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Serial number" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Command="{Binding ToggleSerialVisibilityCommand}"
                                Style="{StaticResource ValuePillButtonStyle}"
                                HorizontalAlignment="Right"
                                Padding="12,6">
                            <TextBlock Margin="16,8" Text="{Binding DisplaySerial}" Foreground="White" FontFamily="Consolas" FontSize="12" d:Text="..." />
                        </Button>
                    </Grid>
                </Border>

                <Border Style="{StaticResource InfoChipBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Software version" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding CurrentSoftwareVersion}" Foreground="White" FontSize="13" HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>
                </Border>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
