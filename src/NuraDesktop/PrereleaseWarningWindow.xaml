<Window x:Class="NuraDesktop.PrereleaseWarningWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prerelease warning"
        Width="540"
        Height="500"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="PrereleaseWarningCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource StrongTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="CheckBoxChrome"
                                    Width="22"
                                    Height="22"
                                    CornerRadius="7"
                                    Background="#10FFFFFF"
                                    BorderBrush="#28FFFFFF"
                                    BorderThickness="1"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="CheckMark"
                                           Text="✓"
                                           Foreground="White"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Opacity="0" />
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              Margin="10,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBoxChrome" Property="Background" Value="{StaticResource AccentGradientBrush}" />
                                <Setter TargetName="CheckBoxChrome" Property="BorderBrush" Value="#55FF8AE6" />
                                <Setter TargetName="CheckMark" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBoxChrome" Property="BorderBrush" Value="#44FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrereleaseWarningPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ValuePillButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentGradientBrush}" />
            <Setter Property="BorderBrush" Value="#44FF8AE6" />
            <Setter Property="Height" Value="46" />
            <Setter Property="MinWidth" Value="170" />
            <Setter Property="Padding" Value="18,8" />
        </Style>
    </Window.Resources>

    <Grid>
        <Border Style="{StaticResource PopupShellStyle}">
            <Grid>
                <Border IsHitTestVisible="False">
                    <Border.Background>
                        <RadialGradientBrush Center="0.5,0.0"
                                             GradientOrigin="0.5,0.0"
                                             RadiusX="0.92"
                                             RadiusY="0.72">
                            <GradientStop Color="#36D946EF" Offset="0.0" />
                            <GradientStop Color="#20D946EF" Offset="0.22" />
                            <GradientStop Color="#0FD946EF" Offset="0.38" />
                            <GradientStop Color="#00D946EF" Offset="0.62" />
                        </RadialGradientBrush>
                    </Border.Background>
                </Border>

                <Grid Margin="26">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="48"
                                Height="48"
                                CornerRadius="18"
                                Background="#18FFFFFF"
                                BorderBrush="#28FFFFFF"
                                BorderThickness="1"
                                VerticalAlignment="Top">
                            <TextBlock Text="!"
                                       Foreground="White"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" 
                                       LineHeight="28"
                                       LineStackingStrategy="BlockLineHeight" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                            <TextBlock Text="Prerelease build"
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       TextOptions.TextFormattingMode="Display" />
                            <TextBlock Text="Use this version with caution"
                                       Foreground="{StaticResource StrongTextBrush}"
                                       FontSize="26"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1"
                            Style="{StaticResource CardBorderStyle}"
                            Padding="20"
                            Margin="0,24,0,22">
                        <StackPanel>
                            <TextBlock 
                                       Foreground="{StaticResource StrongTextBrush}"
                                       FontSize="15"
                                       LineHeight="23"
                                       TextWrapping="Wrap">
                                <Run Text="This desktop app is a prerelease build and is still under active development. It" />
                                <Run Text="WILL" FontWeight="ExtraBold" />
                                <Run Text="contain bugs, incomplete behaviour, or device-control issues." />
                            </TextBlock>
                            <TextBlock Text="For regular use, it is strongly recommended that you run NuraApp instead of this build. Continue only if you understand that the UI is glitchy and work in progress."
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       FontSize="14"
                                       LineHeight="22"
                                       TextWrapping="Wrap"
                                       Margin="0,16,0,0" />

                            <Border Background="#12FFFFFF"
                                    BorderBrush="#22FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="14"
                                    Margin="0,20,0,0">
                                <TextBlock Text="Some features may not work reliably and settings or device state could behave unexpectedly. Even if this is a pre-release, do not fear of any device issues as this cannot cause your Nura devices damage."
                                           Foreground="{StaticResource SubtleTextBrush}"
                                           FontSize="13"
                                           LineHeight="20"
                                           TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="DoNotShowAgainCheckBox"
                                  Grid.Column="0"
                                  Content="Do not show this warning again"
                                  Style="{StaticResource PrereleaseWarningCheckBoxStyle}"
                                  VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Style="{StaticResource PrereleaseWarningPrimaryButtonStyle}"
                                Click="ContinueButton_OnClick"
                                IsDefault="True">
                            <TextBlock Text="Continue anyway"
                                       Foreground="White"
                                       FontSize="13"
                                       FontWeight="SemiBold" />
                        </Button>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
