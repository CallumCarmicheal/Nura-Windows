<UserControl x:Class="NuraPopupWpf.Controls.ShellStatusControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:NuraPopupWpf.Models"
             xmlns:local="clr-namespace:NuraPopupWpf.Controls"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="58" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Text="SYSTEM"
                   Foreground="#8FFFFFFF"
                   FontSize="10"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center" />
        <TextBlock Grid.Column="1"
                   Text="{Binding GlobalStatusText}"
                   Foreground="#D9FFFFFF"
                   FontSize="12"
                   TextTrimming="CharacterEllipsis"
                   VerticalAlignment="Center">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="#D9FFFFFF" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding GlobalStatusTone}" Value="{x:Static models:StatusTone.Success}">
                            <Setter Property="Foreground" Value="#A8F0C7" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding GlobalStatusTone}" Value="{x:Static models:StatusTone.Warning}">
                            <Setter Property="Foreground" Value="#FFD28A" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding GlobalStatusTone}" Value="{x:Static models:StatusTone.Error}">
                            <Setter Property="Foreground" Value="#FF9EA8" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <TextBlock Grid.Row="1"
                   Text="DEVICE"
                   Foreground="#8FFFFFFF"
                   FontSize="10"
                   FontWeight="SemiBold"
                   Margin="0,5,0,0"
                   VerticalAlignment="Center" />
        <local:PendingValueText Grid.Row="1"
                                Grid.Column="1"
                                Text="{Binding CurrentDeviceStatusText}"
                                IsPending="{Binding CurrentDeviceHasPendingChanges}"
                                Foreground="#BFFFFFFF"
                                FontSize="12"
                                Margin="0,5,0,0"
                                VerticalAlignment="Center">
            <local:PendingValueText.Style>
                <Style TargetType="local:PendingValueText">
                    <Setter Property="Foreground" Value="#BFFFFFFF" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentDeviceStatusTone}" Value="{x:Static models:StatusTone.Success}">
                            <Setter Property="Foreground" Value="#A8F0C7" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurrentDeviceStatusTone}" Value="{x:Static models:StatusTone.Warning}">
                            <Setter Property="Foreground" Value="#FFD28A" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurrentDeviceStatusTone}" Value="{x:Static models:StatusTone.Error}">
                            <Setter Property="Foreground" Value="#FF9EA8" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </local:PendingValueText.Style>
        </local:PendingValueText>
    </Grid>
</UserControl>
