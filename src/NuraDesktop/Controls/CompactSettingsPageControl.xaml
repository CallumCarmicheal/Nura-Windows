<UserControl x:Class="NuraDesktop.Controls.CompactSettingsPageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:NuraDesktop.Models"
             xmlns:local="clr-namespace:NuraDesktop.Controls"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="SettingsComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#10FFFFFF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#22FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
    </UserControl.Resources>
    <StackPanel>
        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="YOUR ACCOUNT" Style="{StaticResource SectionTitleStyle}" />
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,12,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Name" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                        <TextBlock Grid.Column="1" Text="{Binding AccountNameDisplay}" Foreground="White" HorizontalAlignment="Right" />
                    </Grid>
                </Border>
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Email address" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                        <TextBlock Grid.Column="1" Text="{Binding AccountEmailDisplay}" Foreground="White" HorizontalAlignment="Right" TextWrapping="Wrap" />
                    </Grid>
                </Border>
                <Button Margin="0,0,0,16"
                        Command="{Binding LogoutAuthenticationCommand}"
                        Style="{StaticResource ValuePillButtonStyle}"
                        HorizontalAlignment="Stretch"
                        Visibility="{Binding HasAuthenticatedWithNura, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock FontFamily="Segoe Fluent Icons"
                                   Text="&#xE8AC;"
                                   Foreground="#FFD18B9A"
                                   FontSize="13"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="Log out"
                                   Foreground="White"
                                   FontSize="13"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Button>
                <Button Margin="0,0,0,16"
                        Command="{Binding ReopenAuthenticationCommand}"
                        HorizontalAlignment="Stretch">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ValuePillButtonStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasAuthenticatedWithNura}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock FontFamily="Segoe Fluent Icons"
                                   Text="&#xE721;"
                                   Foreground="#FFB78CFF"
                                   FontSize="13"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="Log in to Nura"
                                   Foreground="White"
                                   FontSize="13"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Button>

                <TextBlock Text="APP" Style="{StaticResource SectionTitleStyle}" Margin="0,12,0,0" />
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Desktop app version" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                        <TextBlock Grid.Column="1" Text="1.2.0-rc2" Foreground="White" HorizontalAlignment="Right" />
                    </Grid>
                </Border>
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Use bitmap renderer" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                            <TextBlock Text="{Binding ProfileRendererSubtitle}" Foreground="White" FontSize="13" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleButton Grid.Column="1"
                                      IsChecked="{Binding UseBitmapProfileRenderer, Mode=TwoWay}"
                                      Style="{StaticResource SwitchToggleButtonStyle}" />
                    </Grid>
                </Border>
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,10,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Connect to Nura" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                            <TextBlock Text="{Binding ConnectToNuraSubtitle}" Foreground="White" FontSize="13" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleButton Grid.Column="1"
                                      IsChecked="{Binding ConnectToNura, Mode=TwoWay}"
                                      Style="{StaticResource SwitchToggleButtonStyle}" />
                    </Grid>
                </Border>
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,10,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Auto setup devices" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                            <TextBlock Text="{Binding AutoSetupDevicesSubtitle}" Foreground="White" FontSize="13" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleButton Grid.Column="1"
                                      IsChecked="{Binding AutoSetupDevices, Mode=TwoWay}"
                                      Style="{StaticResource SwitchToggleButtonStyle}" />
                    </Grid>
                </Border>
                <TextBlock Text="USER INTERFACE" Style="{StaticResource SectionTitleStyle}" Margin="0,16,0,0" />
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="Band layout" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                        <StackPanel>
                            
                        </StackPanel>
                        <Slider Margin="0,4,0,0"
                                Minimum="0"
                                Maximum="2"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Value="{Binding ProfileBandLayoutIndex, Mode=TwoWay}"
                                Style="{StaticResource ThreeStateSliderStyle}" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Circular"
                                       Grid.Column="0"
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       FontSize="11"
                                       HorizontalAlignment="Left" />
                            <TextBlock Text="Both"
                                       Grid.Column="1"
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       FontSize="11"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Pill"
                                       Grid.Column="2"
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       FontSize="11"
                                       HorizontalAlignment="Right" />
                        </Grid>

                        <TextBlock Margin="0,8,0,0" Text="{Binding ProfileBandLayoutSubtitle}" Foreground="White" FontSize="13" TextWrapping="Wrap" 
                                   MinHeight="35" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,10,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Show profile background haze" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                            <TextBlock Text="Expanded view only. Restore the large blurred purple haze behind the profile canvas." Foreground="White" FontSize="13" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleButton Grid.Column="1"
                                      IsChecked="{Binding ShowProfileBackgroundHaze, Mode=TwoWay}"
                                      Style="{StaticResource SwitchToggleButtonStyle}" />
                    </Grid>
                </Border>
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="Anchor" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                        <TextBlock Text="{Binding WindowAnchorSubtitle}" Foreground="White" FontSize="13" TextWrapping="Wrap" Margin="0,2,0,0" />
                        <ListBox x:Name="AnchorModeListBox"
                                 Margin="0,10,0,0"
                                 ItemsSource="{Binding WindowAnchorOptions}"
                                 SelectedItem="{Binding SelectedWindowAnchorOption, Mode=TwoWay}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 PreviewMouseLeftButtonDown="AnchorModeListBox_PreviewMouseLeftButtonDown"
                                 PreviewMouseLeftButtonUp="AnchorModeListBox_PreviewMouseLeftButtonUp"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                 ItemContainerStyle="{StaticResource PillListBoxItemStyle}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Label}" Foreground="White" FontWeight="SemiBold" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <ToggleButton x:Name="AnchorEdgeSelectorButton"
                                      Margin="0,12,0,0"
                                      Background="#10FFFFFF"
                                      BorderBrush="#22FFFFFF"
                                      BorderThickness="1"
                                      Foreground="White"
                                      Padding="12,10"
                                      Visibility="{Binding ShowAnchorEdgeSelector, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="Chrome"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}"
                                            CornerRadius="18">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Chrome" Property="Background" Value="#16FFFFFF" />
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Chrome" Property="Background" Value="#18FFFFFF" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Anchor edge" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                                    <TextBlock Text="{Binding WindowAnchorEdgeSubtitle}" Foreground="White" FontSize="13" Margin="0,2,0,0" />
                                </StackPanel>
                                <UniformGrid Grid.Column="1"
                                             Rows="3"
                                             Columns="3"
                                             Margin="12,0,0,0"
                                             VerticalAlignment="Center">
                                    <Border Width="7" Height="7" CornerRadius="3.5" Margin="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#28FFFFFF" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAnchorEdgeTopLeftSelected}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource AccentGradientBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border Width="7" Height="7" CornerRadius="3.5" Margin="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#28FFFFFF" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAnchorEdgeTopCenterSelected}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource AccentGradientBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border Width="7" Height="7" CornerRadius="3.5" Margin="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#28FFFFFF" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAnchorEdgeTopRightSelected}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource AccentGradientBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border Width="7" Height="7" CornerRadius="3.5" Margin="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#28FFFFFF" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAnchorEdgeMiddleLeftSelected}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource AccentGradientBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border Width="7" Height="7" CornerRadius="3.5" Margin="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#28FFFFFF" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAnchorEdgeCenterSelected}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource AccentGradientBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border Width="7" Height="7" CornerRadius="3.5" Margin="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#28FFFFFF" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAnchorEdgeMiddleRightSelected}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource AccentGradientBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border Width="7" Height="7" CornerRadius="3.5" Margin="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#28FFFFFF" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAnchorEdgeBottomLeftSelected}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource AccentGradientBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border Width="7" Height="7" CornerRadius="3.5" Margin="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#28FFFFFF" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAnchorEdgeBottomCenterSelected}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource AccentGradientBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border Width="7" Height="7" CornerRadius="3.5" Margin="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#28FFFFFF" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAnchorEdgeBottomRightSelected}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource AccentGradientBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </UniformGrid>
                                <TextBlock Grid.Column="2"
                                           FontFamily="Segoe Fluent Icons"
                                           Text="&#xE70D;"
                                           Margin="10,0,0,0"
                                           Foreground="{StaticResource SubtleTextBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </ToggleButton>
                        <Popup x:Name="AnchorEdgePopup"
                               IsOpen="{Binding IsChecked, ElementName=AnchorEdgeSelectorButton}"
                               Closed="AnchorEdgePopup_OnClosed"
                               AllowsTransparency="True"
                               Placement="Bottom"
                               PlacementTarget="{Binding ElementName=AnchorEdgeSelectorButton}"
                               VerticalOffset="8"
                               PopupAnimation="Fade"
                               StaysOpen="False">
                            <Border Width="{Binding ActualWidth, ElementName=AnchorEdgeSelectorButton}"
                                    Background="#F2121212"
                                    BorderBrush="#22FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="20"
                                    Padding="8">
                                <UniformGrid Rows="3" Columns="3">
                                    <Button Margin="4" Padding="10,8" Command="{Binding SelectWindowAnchorEdgeCommand}" CommandParameter="{x:Static models:WindowAnchorEdge.TopLeft}" Click="AnchorEdgeOptionButton_OnClick">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ValuePillButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAnchorEdgeTopLeftSelected}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource AccentGradientBrush}" />
                                                        <Setter Property="BorderBrush" Value="#44FF8AE6" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="Top left" Foreground="White" FontSize="12" FontWeight="SemiBold" TextAlignment="Center" />
                                    </Button>
                                    <Button Margin="4" Padding="10,8" Command="{Binding SelectWindowAnchorEdgeCommand}" CommandParameter="{x:Static models:WindowAnchorEdge.TopCenter}" Click="AnchorEdgeOptionButton_OnClick">
                                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource ValuePillButtonStyle}"><Style.Triggers><DataTrigger Binding="{Binding IsAnchorEdgeTopCenterSelected}" Value="True"><Setter Property="Background" Value="{StaticResource AccentGradientBrush}" /><Setter Property="BorderBrush" Value="#44FF8AE6" /></DataTrigger></Style.Triggers></Style></Button.Style>
                                        <TextBlock Text="Top center" Foreground="White" FontSize="12" FontWeight="SemiBold" TextAlignment="Center" />
                                    </Button>
                                    <Button Margin="4" Padding="10,8" Command="{Binding SelectWindowAnchorEdgeCommand}" CommandParameter="{x:Static models:WindowAnchorEdge.TopRight}" Click="AnchorEdgeOptionButton_OnClick">
                                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource ValuePillButtonStyle}"><Style.Triggers><DataTrigger Binding="{Binding IsAnchorEdgeTopRightSelected}" Value="True"><Setter Property="Background" Value="{StaticResource AccentGradientBrush}" /><Setter Property="BorderBrush" Value="#44FF8AE6" /></DataTrigger></Style.Triggers></Style></Button.Style>
                                        <TextBlock Text="Top right" Foreground="White" FontSize="12" FontWeight="SemiBold" TextAlignment="Center" />
                                    </Button>
                                    <Button Margin="4" Padding="10,8" Command="{Binding SelectWindowAnchorEdgeCommand}" CommandParameter="{x:Static models:WindowAnchorEdge.MiddleLeft}" Click="AnchorEdgeOptionButton_OnClick">
                                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource ValuePillButtonStyle}"><Style.Triggers><DataTrigger Binding="{Binding IsAnchorEdgeMiddleLeftSelected}" Value="True"><Setter Property="Background" Value="{StaticResource AccentGradientBrush}" /><Setter Property="BorderBrush" Value="#44FF8AE6" /></DataTrigger></Style.Triggers></Style></Button.Style>
                                        <TextBlock Text="Middle left" Foreground="White" FontSize="12" FontWeight="SemiBold" TextAlignment="Center" />
                                    </Button>
                                    <Button Margin="4" Padding="10,8" Command="{Binding SelectWindowAnchorEdgeCommand}" CommandParameter="{x:Static models:WindowAnchorEdge.Center}" Click="AnchorEdgeOptionButton_OnClick">
                                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource ValuePillButtonStyle}"><Style.Triggers><DataTrigger Binding="{Binding IsAnchorEdgeCenterSelected}" Value="True"><Setter Property="Background" Value="{StaticResource AccentGradientBrush}" /><Setter Property="BorderBrush" Value="#44FF8AE6" /></DataTrigger></Style.Triggers></Style></Button.Style>
                                        <TextBlock Text="Center" Foreground="White" FontSize="12" FontWeight="SemiBold" TextAlignment="Center" />
                                    </Button>
                                    <Button Margin="4" Padding="10,8" Command="{Binding SelectWindowAnchorEdgeCommand}" CommandParameter="{x:Static models:WindowAnchorEdge.MiddleRight}" Click="AnchorEdgeOptionButton_OnClick">
                                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource ValuePillButtonStyle}"><Style.Triggers><DataTrigger Binding="{Binding IsAnchorEdgeMiddleRightSelected}" Value="True"><Setter Property="Background" Value="{StaticResource AccentGradientBrush}" /><Setter Property="BorderBrush" Value="#44FF8AE6" /></DataTrigger></Style.Triggers></Style></Button.Style>
                                        <TextBlock Text="Middle right" Foreground="White" FontSize="12" FontWeight="SemiBold" TextAlignment="Center" />
                                    </Button>
                                    <Button Margin="4" Padding="10,8" Command="{Binding SelectWindowAnchorEdgeCommand}" CommandParameter="{x:Static models:WindowAnchorEdge.BottomLeft}" Click="AnchorEdgeOptionButton_OnClick">
                                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource ValuePillButtonStyle}"><Style.Triggers><DataTrigger Binding="{Binding IsAnchorEdgeBottomLeftSelected}" Value="True"><Setter Property="Background" Value="{StaticResource AccentGradientBrush}" /><Setter Property="BorderBrush" Value="#44FF8AE6" /></DataTrigger></Style.Triggers></Style></Button.Style>
                                        <TextBlock Text="Bottom left" Foreground="White" FontSize="12" FontWeight="SemiBold" TextAlignment="Center" />
                                    </Button>
                                    <Button Margin="4" Padding="10,8" Command="{Binding SelectWindowAnchorEdgeCommand}" CommandParameter="{x:Static models:WindowAnchorEdge.BottomCenter}" Click="AnchorEdgeOptionButton_OnClick">
                                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource ValuePillButtonStyle}"><Style.Triggers><DataTrigger Binding="{Binding IsAnchorEdgeBottomCenterSelected}" Value="True"><Setter Property="Background" Value="{StaticResource AccentGradientBrush}" /><Setter Property="BorderBrush" Value="#44FF8AE6" /></DataTrigger></Style.Triggers></Style></Button.Style>
                                        <TextBlock Text="Bottom center" Foreground="White" FontSize="12" FontWeight="SemiBold" TextAlignment="Center" />
                                    </Button>
                                    <Button Margin="4" Padding="10,8" Command="{Binding SelectWindowAnchorEdgeCommand}" CommandParameter="{x:Static models:WindowAnchorEdge.BottomRight}" Click="AnchorEdgeOptionButton_OnClick">
                                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource ValuePillButtonStyle}"><Style.Triggers><DataTrigger Binding="{Binding IsAnchorEdgeBottomRightSelected}" Value="True"><Setter Property="Background" Value="{StaticResource AccentGradientBrush}" /><Setter Property="BorderBrush" Value="#44FF8AE6" /></DataTrigger></Style.Triggers></Style></Button.Style>
                                        <TextBlock Text="Bottom right" Foreground="White" FontSize="12" FontWeight="SemiBold" TextAlignment="Center" />
                                    </Button>
                                </UniformGrid>
                            </Border>
                        </Popup>
                        <StackPanel Margin="0,12,0,0"
                                    Visibility="{Binding ShowRememberExpandTypeSelector, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Expand type" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                            <TextBlock Text="{Binding RememberExpandTypeSubtitle}" Foreground="White" FontSize="13" TextWrapping="Wrap" Margin="0,2,0,0" />
                            <ListBox Margin="0,10,0,0"
                                     ItemsSource="{Binding RememberExpandTypeOptions}"
                                     SelectedItem="{Binding SelectedRememberExpandTypeOption, Mode=TwoWay}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     ItemContainerStyle="{StaticResource PillListBoxItemStyle}">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:RememberExpandTypeOption}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Label}" Foreground="White" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,10,0,0">
                    <StackPanel>
                        <Button Command="{Binding ExportHearingProfilesCommand}"
                                Style="{StaticResource ValuePillButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Padding="12,10">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock FontFamily="Segoe Fluent Icons"
                                           Text="&#xEDE1;"
                                           Foreground="White"
                                           FontSize="14"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="Export Hearing Profiles"
                                           Foreground="White"
                                           FontSize="13"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                        <TextBlock Text="{Binding ExportStatusText}"
                                   Margin="0,10,0,0"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="#22FFFFFF" Width="4" Margin="0,8" CornerRadius="4"></Border>

                    <Border Grid.Column="1" Style="{StaticResource InfoChipBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="92" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Render size" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                                <TextBlock Text="PNG size in pixels. Min 4, max 12288." Foreground="White" FontSize="13" TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Background="#10FFFFFF"
                                    BorderBrush="#22FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="24"
                                    SnapsToDevicePixels="True"
                                    Margin="20,0,0,0">
                                <TextBox Text="{Binding ExportRenderSizeText, UpdateSourceTrigger=PropertyChanged}" d:Text="12288"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="White"
                                         Padding="16,8"
                                         TextAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         PreviewTextInput="NumberOnly_PreviewTextInput"
                                         DataObject.Pasting="NumberOnly_Pasting" />
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Text="DEVICE SETTINGS" Style="{StaticResource SectionTitleStyle}" />
                <ListBox x:Name="DeviceListBox"
                         Margin="0,12,0,16"
                         ItemsSource="{Binding VisibleDevices}"
                         SelectedItem="{Binding CurrentDevice, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent"
                         ItemContainerStyle="{StaticResource DeviceRailListBoxItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:DeviceModel}">
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Opacity" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                                <Setter Property="Opacity" Value="0.54" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="10" Height="10" Margin="0,2,10,0" VerticalAlignment="Top">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#55FFFFFF" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                    <Setter Property="Fill" Value="#FF64FFB0" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="White"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding DeviceStatusSummary, Mode=OneWay}"
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               FontSize="12"
                                               Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding WarningText}"
                                               Foreground="#FFFFB25F"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Margin="0,4,0,0"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasWarningText}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <ToggleButton x:Name="MoreDevicesButton"
                              Margin="0,0,0,16"
                              Background="#10FFFFFF"
                              BorderBrush="#22FFFFFF"
                              BorderThickness="1"
                              Foreground="White"
                              Padding="12,8"
                              HorizontalAlignment="Stretch"
                              Visibility="{Binding HasOverflowDevices, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="Chrome"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}"
                                    CornerRadius="16">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Chrome" Property="Background" Value="#16FFFFFF" />
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Chrome" Property="Background" Value="#18FFFFFF" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding MoreDevicesButtonText}" />
                        <TextBlock FontFamily="Segoe Fluent Icons"
                                   Text="&#xE70D;"
                                   Margin="8,0,0,0"
                                   Foreground="{StaticResource SubtleTextBrush}" />
                    </StackPanel>
                </ToggleButton>
                <Popup x:Name="MoreDevicesPopup"
                       IsOpen="{Binding IsChecked, ElementName=MoreDevicesButton}"
                       Closed="MoreDevicesPopup_OnClosed"
                       AllowsTransparency="True"
                       Placement="Bottom"
                       PlacementTarget="{Binding ElementName=MoreDevicesButton}"
                       VerticalOffset="8"
                       PopupAnimation="Fade"
                       StaysOpen="False">
                    <Border Width="{Binding ActualWidth, ElementName=MoreDevicesButton}"
                            Background="#F2121212"
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1"
                            CornerRadius="20"
                            Padding="6">
                        <ListBox ItemsSource="{Binding OverflowDevices}"
                                 SelectedItem="{Binding CurrentDevice, Mode=TwoWay}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ItemContainerStyle="{StaticResource DeviceRailListBoxItemStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:DeviceModel}">
                                    <Grid>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Opacity" Value="1" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                                        <Setter Property="Opacity" Value="0.54" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Width="10" Height="10" Margin="0,2,10,0" VerticalAlignment="Top">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#55FFFFFF" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                            <Setter Property="Fill" Value="#FF64FFB0" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="White"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding DeviceStatusSummary, Mode=OneWay}"
                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                       FontSize="12"
                                                       Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding WarningText}"
                                                       Foreground="#FFFFB25F"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Margin="0,4,0,0"
                                                       TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasWarningText}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Popup>
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Opacity" Value="1" />
                            <Setter Property="IsEnabled" Value="True" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShouldBlurCurrentDeviceControls}" Value="True">
                                    <Setter Property="Opacity" Value="0.4" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,10"
                            Visibility="{Binding ShowCurrentDeviceActionPanel, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="LIVE CONTROL" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                            <TextBlock Text="{Binding CurrentDeviceReadinessText}" Foreground="#D9FFFFFF" FontSize="13" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding CurrentDeviceActionText}" Foreground="White" FontSize="13" TextWrapping="Wrap" />
                            <WrapPanel Margin="0,10,0,0">
                                <Button Command="{Binding RefreshDevicesCommand}" Style="{StaticResource ValuePillButtonStyle}" Padding="12,6" Margin="0,0,8,8">
                                    <TextBlock Text="Refresh devices" Foreground="White" />
                                </Button>
                                <Button Command="{Binding ConnectCurrentDeviceCommand}" Style="{StaticResource ValuePillButtonStyle}" Padding="12,6" Margin="0,0,8,8">
                                    <TextBlock Text="Connect" Foreground="White" />
                                </Button>
                                <Button Command="{Binding RefreshCurrentDeviceCommand}" Style="{StaticResource ValuePillButtonStyle}" Padding="12,6" Margin="0,0,8,8">
                                    <TextBlock Text="Refresh state" Foreground="White" />
                                </Button>
                                <Button Command="{Binding RefreshBatteryCommand}" Style="{StaticResource ValuePillButtonStyle}" Padding="12,6" Margin="0,0,8,8">
                                    <TextBlock Text="Battery" Foreground="White" />
                                </Button>
                                <Button Command="{Binding ProvisionCurrentDeviceCommand}" Style="{StaticResource ValuePillButtonStyle}" Padding="12,6" Margin="0,0,8,8">
                                    <TextBlock Text="Provision" Foreground="White" />
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,10"
                            Visibility="{Binding ShowAncControl, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="ANC" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                                <local:PendingValueText Text="{Binding CurrentDevice.DisplayAncStatusText}"
                                                        IsPending="{Binding CurrentDevice.IsAncPending}"
                                                        FontSize="13" d:Text="..." />
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          Command="{Binding ToggleAncCommand}"
                                          IsChecked="{Binding CurrentDevice.DisplayAncEnabled, Mode=OneWay}"
                                          Tag="{Binding CurrentDevice.IsAncPending}"
                                          Style="{StaticResource SwitchToggleButtonStyle}" />
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,10"
                            Visibility="{Binding ShowPassthroughControl, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Social mode" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                                <local:PendingValueText Text="{Binding CurrentDevice.DisplaySocialModeText}"
                                                        IsPending="{Binding CurrentDevice.IsPassthroughPending}"
                                                        FontSize="13" />
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          Command="{Binding TogglePassthroughCommand}"
                                          IsChecked="{Binding CurrentDevice.DisplaySocialMode, Mode=OneWay}"
                                          Tag="{Binding CurrentDevice.IsPassthroughPending}"
                                          Style="{StaticResource SwitchToggleButtonStyle}" />
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,10"
                            Visibility="{Binding ShowAncLevelControl, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="ANC level" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                            <TextBlock Text="{Binding CurrentAncLevelText}" Foreground="White" FontSize="13" Margin="0,2,0,0" />
                            <Slider Minimum="0"
                                    Maximum="4"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding CurrentAncLevelValue, Mode=TwoWay}"
                                    Margin="0,10,0,0" />
                            <Button Command="{Binding ApplyAncLevelCommand}"
                                    Style="{StaticResource ValuePillButtonStyle}"
                                    Padding="12,6"
                                    Margin="0,10,0,0"
                                    HorizontalAlignment="Right">
                                <TextBlock Text="Apply ANC level" Foreground="White" />
                            </Button>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,10"
                            Visibility="{Binding ShowSpatialControl, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Spatial audio" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                                <local:PendingValueText Text="{Binding CurrentDevice.DisplaySpatialStatusText}"
                                                        IsPending="{Binding CurrentDevice.IsSpatialPending}"
                                                        FontSize="13" />
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          Command="{Binding ToggleSpatialCommand}"
                                          IsChecked="{Binding CurrentDevice.DisplaySpatialEnabled, Mode=OneWay}"
                                          Tag="{Binding CurrentDevice.IsSpatialPending}"
                                          Style="{StaticResource SwitchToggleButtonStyle}" />
                        </Grid>
                    </Border>

                    <!-- TODO: Grid is disabled until touch button SDK support is added -->
                    <Grid Visibility="Collapsed">
                        <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,10"
                                Visibility="{Binding ShowTouchButtonControls, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Touch buttons" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                                <TextBlock Text="Per-side gesture bindings from the live SDK surface." Foreground="White" FontSize="13" TextWrapping="Wrap" Margin="0,2,0,0" />
                                <TextBlock Text="Left single tap" Foreground="{StaticResource SubtleTextBrush}" FontSize="12" Margin="0,10,0,0" />
                                <ComboBox ItemsSource="{Binding SingleTapButtonOptions}" SelectedItem="{Binding SelectedLeftSingleTapButtonFunction, Mode=TwoWay}" DisplayMemberPath="Label" Style="{StaticResource SettingsComboBoxStyle}" />
                                <TextBlock Text="Right single tap" Foreground="{StaticResource SubtleTextBrush}" FontSize="12" Margin="0,8,0,0" />
                                <ComboBox ItemsSource="{Binding SingleTapButtonOptions}" SelectedItem="{Binding SelectedRightSingleTapButtonFunction, Mode=TwoWay}" DisplayMemberPath="Label" Style="{StaticResource SettingsComboBoxStyle}" />
                                <StackPanel Visibility="{Binding ShowDoubleTapBindings, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Left double tap" Foreground="{StaticResource SubtleTextBrush}" FontSize="12" Margin="0,8,0,0" />
                                    <ComboBox ItemsSource="{Binding DoubleTapButtonOptions}" SelectedItem="{Binding SelectedLeftDoubleTapButtonFunction, Mode=TwoWay}" DisplayMemberPath="Label" Style="{StaticResource SettingsComboBoxStyle}" />
                                    <TextBlock Text="Right double tap" Foreground="{StaticResource SubtleTextBrush}" FontSize="12" Margin="0,8,0,0" />
                                    <ComboBox ItemsSource="{Binding DoubleTapButtonOptions}" SelectedItem="{Binding SelectedRightDoubleTapButtonFunction, Mode=TwoWay}" DisplayMemberPath="Label" Style="{StaticResource SettingsComboBoxStyle}" />
                                </StackPanel>
                                <StackPanel Visibility="{Binding ShowTripleTapBindings, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Left triple tap" Foreground="{StaticResource SubtleTextBrush}" FontSize="12" Margin="0,8,0,0" />
                                    <ComboBox ItemsSource="{Binding TripleTapButtonOptions}" SelectedItem="{Binding SelectedLeftTripleTapButtonFunction, Mode=TwoWay}" DisplayMemberPath="Label" Style="{StaticResource SettingsComboBoxStyle}" />
                                    <TextBlock Text="Right triple tap" Foreground="{StaticResource SubtleTextBrush}" FontSize="12" Margin="0,8,0,0" />
                                    <ComboBox ItemsSource="{Binding TripleTapButtonOptions}" SelectedItem="{Binding SelectedRightTripleTapButtonFunction, Mode=TwoWay}" DisplayMemberPath="Label" Style="{StaticResource SettingsComboBoxStyle}" />
                                </StackPanel>
                                <StackPanel Visibility="{Binding ShowTapAndHoldBindings, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Left tap and hold" Foreground="{StaticResource SubtleTextBrush}" FontSize="12" Margin="0,8,0,0" />
                                    <ComboBox ItemsSource="{Binding TapAndHoldButtonOptions}" SelectedItem="{Binding SelectedLeftTapAndHoldButtonFunction, Mode=TwoWay}" DisplayMemberPath="Label" Style="{StaticResource SettingsComboBoxStyle}" />
                                    <TextBlock Text="Right tap and hold" Foreground="{StaticResource SubtleTextBrush}" FontSize="12" Margin="0,8,0,0" />
                                    <ComboBox ItemsSource="{Binding TapAndHoldButtonOptions}" SelectedItem="{Binding SelectedRightTapAndHoldButtonFunction, Mode=TwoWay}" DisplayMemberPath="Label" Style="{StaticResource SettingsComboBoxStyle}" />
                                </StackPanel>
                                <WrapPanel Margin="0,12,0,0">
                                    <Button Command="{Binding ApplyTouchButtonsCommand}" Style="{StaticResource ValuePillButtonStyle}" Padding="12,6" Margin="0,0,8,0">
                                        <TextBlock Text="Apply buttons" Foreground="White" />
                                    </Button>
                                    <Button Command="{Binding ResetTouchButtonsCommand}" Style="{StaticResource ValuePillButtonStyle}" Padding="12,6">
                                        <TextBlock Text="Reset" Foreground="White" />
                                    </Button>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                    
                    <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,10"
                            Visibility="{Binding ShowDialControls, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Dial bindings" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                            <TextBlock Text="Available on supported NuraLoop-family devices." Foreground="White" FontSize="13" Margin="0,2,0,0" />
                        <TextBlock Text="Left dial" Foreground="{StaticResource SubtleTextBrush}" FontSize="12" Margin="0,10,0,0" />
                        <ComboBox ItemsSource="{Binding DialFunctionOptions}" SelectedItem="{Binding SelectedLeftDialFunction, Mode=TwoWay}" DisplayMemberPath="Label" Style="{StaticResource SettingsComboBoxStyle}" />
                        <TextBlock Text="Right dial" Foreground="{StaticResource SubtleTextBrush}" FontSize="12" Margin="0,8,0,0" />
                        <ComboBox ItemsSource="{Binding DialFunctionOptions}" SelectedItem="{Binding SelectedRightDialFunction, Mode=TwoWay}" DisplayMemberPath="Label" Style="{StaticResource SettingsComboBoxStyle}" />
                        <WrapPanel Margin="0,12,0,0">
                            <Button Command="{Binding ApplyDialCommand}" Style="{StaticResource ValuePillButtonStyle}" Padding="12,6" Margin="0,0,8,0">
                                <TextBlock Text="Apply dial" Foreground="White" />
                            </Button>
                            <Button Command="{Binding ResetDialCommand}" Style="{StaticResource ValuePillButtonStyle}" Padding="12,6">
                                <TextBlock Text="Reset" Foreground="White" />
                            </Button>
                        </WrapPanel>
                    </StackPanel>
                </Border>
                    <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,10"
                            Visibility="{Binding ShowEuVolumeLimiterControl, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Enable EU volume limiter" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                                <TextBlock Text="Protect output levels" Foreground="White" FontSize="13" />
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          IsChecked="{Binding CurrentDevice.EuVolumeLimiter, Mode=TwoWay}"
                                          Style="{StaticResource SwitchToggleButtonStyle}" />
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Serial number" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Command="{Binding ToggleSerialVisibilityCommand}"
                                    Style="{StaticResource ValuePillButtonStyle}"
                                    HorizontalAlignment="Right"
                                    Padding="12,6">
                                <TextBlock Margin="16,8" Text="{Binding DisplaySerial}" Foreground="White" FontFamily="Consolas" FontSize="12" d:Text="..." />
                            </Button>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource InfoChipBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Software version" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding CurrentSoftwareVersion}" Foreground="White" FontSize="13" HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
