<UserControl x:Class="NuraDesktop.Controls.ExpandedDevicePageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:NuraDesktop.Models"
             xmlns:local="clr-namespace:NuraDesktop.Controls"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Images/NuraphonesVectors.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" MinHeight="500" Margin="0,0,16,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--<TextBlock Text="{Binding CurrentDevice.Name}"
                               Foreground="White"
                               FontSize="14"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />-->

                    <!--<local:ExpandedProfileSelectorControl Grid.Column="1"
                                                          HorizontalAlignment="Stretch"
                                                          MinWidth="220"
                                                          MaxWidth="420"
                                                          Profiles="{Binding CurrentProfiles}"
                                                          SelectedProfile="{Binding CurrentProfile, Mode=TwoWay}" />-->

                    <!--<Border Grid.Column="2"
                            Background="#10FFFFFF"
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="12,8"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔋" FontSize="12" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding CurrentBatteryText}" Foreground="White" FontSize="12" />
                        </StackPanel>
                    </Border>-->
                </Grid>

                <Grid Grid.Row="1" Margin="0,-64,0,16">
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowDisconnectedDevicePlaceholder}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid x:Name="HazeHost" Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}">
                            <Ellipse HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"
                                     RenderTransformOrigin="0.5,0.5"
                                     Visibility="{Binding ShowProfileBackgroundHaze, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Ellipse.Fill>
                                    <RadialGradientBrush RadiusX="0.5" RadiusY="0.5" Center="0.5,0.5" GradientOrigin="0.5,0.5">
                                        <GradientStop Color="#62D946EF" Offset="0.0" />
                                        <GradientStop Color="#42D946EF" Offset="0.20" />
                                        <GradientStop Color="#1ED946EF" Offset="0.40" />
                                        <GradientStop Color="#08D946EF" Offset="0.64" />
                                        <GradientStop Color="#00D946EF" Offset="0.82" />
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.Effect>
                                    <BlurEffect Radius="132" RenderingBias="Quality" />
                                </Ellipse.Effect>
                                <Ellipse.RenderTransform>
                                    <ScaleTransform ScaleX="2" ScaleY="1.55" />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Grid>

                        <Ellipse Width="480"
                                 Height="380"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                            <Ellipse.Fill>
                                <RadialGradientBrush Center="0.5,0.5"
                                                     GradientOrigin="0.5,0.5"
                                                     RadiusX="0.5"
                                                     RadiusY="0.5">
                                    <GradientStop Color="#14FF57B9" Offset="0" />
                                    <GradientStop Color="#10FF57B9" Offset="0.42" />
                                    <GradientStop Color="#08FF57B9" Offset="0.66" />
                                    <GradientStop Color="#02FF57B9" Offset="0.86" />
                                    <GradientStop Color="#00FF57B9" Offset="1" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>

                        <Grid Visibility="{Binding ShowCircularProfileBands, Converter={StaticResource BoolToVisibilityConverter}}">
                            <!-- Circular bands -->
                            <Ellipse Width="402" Height="402" Stroke="#18FFFFFF" StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Ellipse Width="312" Height="312" Stroke="#12FFFFFF" StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>

                        <Grid 
                              Visibility="{Binding ShowPillProfileBands, Converter={StaticResource BoolToVisibilityConverter}}"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              Margin="18,32">
                            <!-- Pill bands -->
                            <Border Height="312"
                                    Margin="4,0"
                                    CornerRadius="110"
                                    BorderBrush="#18FFFFFF"
                                    BorderThickness="1"
                                    Background="#00000000"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center" />
                            <Border Height="206"
                                    Margin="56,0"
                                    CornerRadius="78"
                                    BorderBrush="#12FFFFFF"
                                    BorderThickness="1"
                                    Background="#00000000"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center" />
                        </Grid>

                        <Grid Width="360" Height="360" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <local:ProfileVisualControl Opacity="1" FromProfile="{Binding VisualFromProfile}"
                                                        ToProfile="{Binding VisualToProfile}"
                                                        ProfileBlendProgress="{Binding VisualProfileBlendProgress}"
                                                        ModeProgress="{Binding VisualModeProgress}"
                                                        UseBitmapRenderer="{Binding UseBitmapProfileRenderer}" />
                        </Grid>
                    </Grid>
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowDisconnectedDevicePlaceholder}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid Width="368"
                              Height="368"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                            <Ellipse Width="368"
                                     Height="368">
                                <Ellipse.Fill>
                                    <RadialGradientBrush Center="0.5,0.5"
                                                         GradientOrigin="0.5,0.5"
                                                         RadiusX="0.9"
                                                         RadiusY="0.5">
                                        <GradientStop Color="#44FFFFFF" Offset="0.0" />
                                        <GradientStop Color="#24FFFFFF" Offset="0.3" />
                                        <GradientStop Color="#10FFFFFF" Offset="0.6" />
                                        <GradientStop Color="#04FFFFFF" Offset="0.8" />
                                        <GradientStop Color="#00FFFFFF" Offset="1.0" />
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.Effect>
                                    <BlurEffect Radius="34" RenderingBias="Quality" />
                                </Ellipse.Effect>
                            </Ellipse>
                            <Grid Margin="54">
                                <Image Source="{StaticResource NuraphonesVectorImage}"
                                       Stretch="Uniform"
                                       Opacity="1" />
                            </Grid>
                        </Grid>
                    </Grid>
                    <Grid HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <Button Command="{Binding ToggleDisconnectedDevicePreviewCommand}"
                                Content="{Binding DisconnectedDevicePreviewButtonText}"
                                Foreground="White" Padding="16,8" Margin="0,0,0,42">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ValuePillButtonStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCurrentDeviceDisconnected}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Grid>

                <StackPanel Grid.Row="2">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Opacity" Value="1" />
                            <Setter Property="IsEnabled" Value="True" />
                            <Setter Property="Effect" Value="{x:Null}" />

                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShouldBlurCurrentDeviceControls}" Value="True">
                                    <Setter Property="Opacity" Value="0.4" />
                                    <Setter Property="IsEnabled" Value="False" />

                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <BlurEffect Radius="6" RenderingBias="Quality" />
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="MODE" Style="{StaticResource SectionTitleStyle}" HorizontalAlignment="Center" 
                               Margin="0,-80,0,0" />
                    <local:ModeSwitchControl Margin="0,-50,0,0"
                                             HorizontalAlignment="Stretch" />

                    <StackPanel Margin="8,20,8,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Opacity" Value="1" />
                                <Setter Property="IsEnabled" Value="True" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CanChangeImmersionControl}" Value="False">
                                        <Setter Property="Opacity" Value="0.45" />
                                        <Setter Property="IsEnabled" Value="False" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Immersion mode" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                        <local:AnimatedSlider Margin="0,12,0,0"
                                              Style="{StaticResource ImmersionSliderStyle}"
                                              Minimum="0"
                                              Maximum="6"
                                              TickFrequency="1"
                                              IsSnapToTickEnabled="True"
                                              Value="{Binding ImmersionIndex, Mode=TwoWay}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Column="1">
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="DEVICES" Style="{StaticResource SectionTitleStyle}" />
                    <ListBox x:Name="DeviceListBox"
                             Margin="0,12,0,0"
                             ItemsSource="{Binding VisibleDevices}"
                             SelectedItem="{Binding CurrentDevice, Mode=TwoWay}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <ListBox.Resources>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource PillListBoxItemStyle}">
                                <Setter Property="Margin" Value="0,0,0,8" />
                            </Style>
                        </ListBox.Resources>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:DeviceModel}">
                                <Grid>
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Opacity" Value="1" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                                    <Setter Property="Opacity" Value="0.54" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#55FFFFFF" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                        <Setter Property="Fill" Value="#FF64FFB0" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    
                                    <StackPanel Grid.Column="1"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="White"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding WarningText}"
                                                   Foreground="#FFFFB25F"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasWarningText}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                Margin="12,0,0,0">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock FontFamily="Segoe Fluent Icons"
                                                   Text="&#xE850;"
                                                   Foreground="{StaticResource SubtleTextBrush}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0" />
                                        <TextBlock Text="{Binding BatteryText}"
                                                   Foreground="{StaticResource SubtleTextBrush}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    
                    <ToggleButton x:Name="MoreDevicesButton"
                                  Margin="0,2,0,0"
                                  Background="#10FFFFFF"
                                  BorderBrush="#22FFFFFF"
                                  BorderThickness="1"
                                  Foreground="White"
                                  Padding="12,8"
                                  HorizontalAlignment="Stretch"
                                  Visibility="{Binding HasOverflowDevices, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="Chrome"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        Padding="{TemplateBinding Padding}"
                                        CornerRadius="16">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Chrome" Property="Background" Value="#16FFFFFF" />
                                    </Trigger>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="Chrome" Property="Background" Value="#18FFFFFF" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding MoreDevicesButtonText}" />
                            <TextBlock FontFamily="Segoe Fluent Icons"
                                       Text="&#xE70D;"
                                       Margin="8,0,0,0"
                                       Foreground="{StaticResource SubtleTextBrush}" />
                        </StackPanel>
                    </ToggleButton>
                    <Popup x:Name="MoreDevicesPopup"
                           IsOpen="{Binding IsChecked, ElementName=MoreDevicesButton}"
                           Closed="MoreDevicesPopup_OnClosed"
                           AllowsTransparency="True"
                           Placement="Bottom"
                           PlacementTarget="{Binding ElementName=MoreDevicesButton}"
                           VerticalOffset="8"
                           PopupAnimation="Fade"
                           StaysOpen="False">
                        <Border Width="{Binding ActualWidth, ElementName=MoreDevicesButton}"
                                Background="#F2121212"
                                BorderBrush="#22FFFFFF"
                                BorderThickness="1"
                                CornerRadius="20"
                                Padding="6">
                            <ListBox ItemsSource="{Binding OverflowDevices}"
                                     SelectedItem="{Binding CurrentDevice, Mode=TwoWay}"
                                     BorderThickness="0"
                                     Background="Transparent">
                                <ListBox.Resources>
                                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource PillListBoxItemStyle}">
                                        <Setter Property="Margin" Value="0,0,0,8" />
                                    </Style>
                                </ListBox.Resources>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:DeviceModel}">
                                        <Grid>
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Opacity" Value="1" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                                            <Setter Property="Opacity" Value="0.54" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#55FFFFFF" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                                <Setter Property="Fill" Value="#FF64FFB0" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="White"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding WarningText}"
                                                           Foreground="#FFFFB25F"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Margin="0,4,0,0"
                                                           TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasWarningText}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        Margin="12,0,0,0">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <TextBlock FontFamily="Segoe Fluent Icons"
                                                           Text="&#xE850;"
                                                           Foreground="{StaticResource SubtleTextBrush}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,6,0" />
                                                <TextBlock Text="{Binding BatteryText}"
                                                           Foreground="{StaticResource SubtleTextBrush}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Popup>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                <StackPanel>
                    
                    
                    <TextBlock Text="CONTROLS" Style="{StaticResource SectionTitleStyle}" />
                    <Grid Margin="0,12,0,0">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Opacity" Value="1" />
                                <Setter Property="IsEnabled" Value="True" />
                                <Setter Property="Effect" Value="{x:Null}" />

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShouldBlurCurrentDeviceControls}" Value="True">
                                        <Setter Property="Opacity" Value="0.4" />
                                        <Setter Property="IsEnabled" Value="False" />

                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <BlurEffect Radius="6" RenderingBias="Quality" />
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,10"
                                Visibility="{Binding ShowPassthroughControl, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Social mode" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                                    <local:PendingValueText Text="{Binding CurrentDevice.DisplaySocialModeText}"
                                                            IsPending="{Binding CurrentDevice.IsPassthroughPending}"
                                                            FontSize="13" />
                                </StackPanel>
                                <ToggleButton Grid.Column="1"
                                              Command="{Binding TogglePassthroughCommand}"
                                              IsChecked="{Binding CurrentDevice.DisplaySocialMode, Mode=OneWay}"
                                              Tag="{Binding CurrentDevice.IsPassthroughPending}"
                                              Style="{StaticResource SwitchToggleButtonStyle}" />
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource InfoChipBorderStyle}"
                                Visibility="{Binding ShowAncControl, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="ANC" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                                    <local:PendingValueText Text="{Binding CurrentDevice.DisplayAncStatusText}"
                                                            IsPending="{Binding CurrentDevice.IsAncPending}"
                                                            FontSize="13" />
                                </StackPanel>
                                <ToggleButton Grid.Column="1"
                                              Command="{Binding ToggleAncCommand}"
                                              IsChecked="{Binding CurrentDevice.DisplayAncEnabled, Mode=OneWay}"
                                              Tag="{Binding CurrentDevice.IsAncPending}"
                                              Style="{StaticResource SwitchToggleButtonStyle}" />
                            </Grid>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="DEVICE INFO" Style="{StaticResource SectionTitleStyle}" />
                    <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,12,0,10">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Device family" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                                <TextBlock Grid.Column="1" d:Text="Nuraphone" Text="{Binding CurrentDevice.DeviceFamilyText}" Foreground="White" FontSize="13"
                                           HorizontalAlignment="Right" />
                            </Grid>

                            <TextBlock d:Text="Device summary text" Text="{Binding CurrentDevice.DeviceCapabilitySummary}" Foreground="{StaticResource SubtleTextBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Serial number" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Command="{Binding ToggleSerialVisibilityCommand}"
                                    Style="{StaticResource ValuePillButtonStyle}"
                                    HorizontalAlignment="Right"
                                    Padding="12,6">
                                <TextBlock Margin="16,8" Text="{Binding DisplaySerial}" Foreground="White" FontFamily="Consolas" FontSize="12" />
                            </Button>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource InfoChipBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Software version" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding CurrentSoftwareVersion}" Foreground="White" FontSize="13" HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
