<Window x:Class="NuraDesktop.StartupSplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Starting Nura"
        Width="440"
        Height="300"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Images/NuraphonesVectors.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Border Style="{StaticResource PopupShellStyle}">
            <Grid>
                <Border IsHitTestVisible="False">
                    <Border.Background>
                        <RadialGradientBrush Center="0.5,0.02"
                                             GradientOrigin="0.5,0.02"
                                             RadiusX="0.92"
                                             RadiusY="0.78">
                            <GradientStop Color="#38A87BFF" Offset="0.0" />
                            <GradientStop Color="#20D946EF" Offset="0.28" />
                            <GradientStop Color="#08FF5AB2" Offset="0.56" />
                            <GradientStop Color="#00FF5AB2" Offset="0.82" />
                        </RadialGradientBrush>
                    </Border.Background>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Width="176" Height="176" HorizontalAlignment="Center">
                        <Ellipse Width="140"
                                 Height="140"
                                 Stroke="#16FFFFFF"
                                 StrokeThickness="1" />
                        <Ellipse Width="132"
                                 Height="132"
                                 Stroke="{StaticResource AccentGradientBrush}"
                                 StrokeThickness="3"
                                 StrokeDashArray="1.5,3"
                                 Opacity="0.85"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform x:Name="LoadingRotation" />
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="LoadingRotation"
                                                             Storyboard.TargetProperty="Angle"
                                                             From="0"
                                                             To="360"
                                                             Duration="0:0:2.4" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>

                        <Image Source="{StaticResource NuraphonesColorVectorImage}"
                               Width="92" Height="92"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,24,0">

                        <TextBlock Text="NURA DESKTOP"
                               Foreground="{StaticResource SubtleTextBrush}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,22,0,0" />
                        <TextBlock Text="Preparing your devices"
                               Foreground="{StaticResource StrongTextBrush}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0" />
                        <TextBlock x:Name="StatusTextBlock"
                               Text="Starting Nura services..."
                               Foreground="{StaticResource SubtleTextBrush}"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0" />
                    </StackPanel>
                </Grid>


            </Grid>
        </Border>
    </Grid>
</Window>
