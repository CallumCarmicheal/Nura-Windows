<Window x:Class="NuraDesktop.UpdateAvailableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nura update available"
        Width="500"
        MinHeight="400"
        SizeToContent="Height"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Closing="Window_OnClosing"
        KeyDown="Window_OnKeyDown">
    <Window.Resources>
        <Style x:Key="UpdatePrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ValuePillButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentGradientBrush}" />
            <Setter Property="BorderBrush" Value="#44FF8AE6" />
            <Setter Property="MinWidth" Value="118" />
            <Setter Property="Padding" Value="18,8" />
        </Style>
        <Style x:Key="UpdateSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ValuePillButtonStyle}">
            <Setter Property="MinWidth" Value="104" />
            <Setter Property="Padding" Value="18,8" />
        </Style>
        <Style x:Key="UpdateLaterButtonStyle" TargetType="Button" BasedOn="{StaticResource UpdateSecondaryButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsUpdateBusy}" Value="True">
                    <Setter Property="IsEnabled" Value="False" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="UpdateSkipVersionCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="IsEnabled" Value="True" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsUpdateBusy}" Value="True">
                    <Setter Property="IsEnabled" Value="False" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Style="{StaticResource PopupShellStyle}">
            <Grid>
                <Border IsHitTestVisible="False">
                    <Border.Background>
                        <RadialGradientBrush Center="0.5,0.0"
                                             GradientOrigin="0.5,0.0"
                                             RadiusX="0.9"
                                             RadiusY="0.72">
                            <GradientStop Color="#34A87BFF" Offset="0.0" />
                            <GradientStop Color="#1DA87BFF" Offset="0.26" />
                            <GradientStop Color="#08A87BFF" Offset="0.52" />
                            <GradientStop Color="#00A87BFF" Offset="0.78" />
                        </RadialGradientBrush>
                    </Border.Background>
                </Border>

                <Grid Margin="26">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="48"
                                Height="48"
                                CornerRadius="18"
                                Background="#18FFFFFF"
                                BorderBrush="#28FFFFFF"
                                BorderThickness="1">
                            <TextBlock Text="&#xE895;"
                                       FontFamily="Segoe Fluent Icons"
                                       Foreground="White"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                            <TextBlock Text="UPDATE AVAILABLE"
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding AvailableUpdateVersionText, StringFormat=Version {0}}"
                                       Foreground="{StaticResource StrongTextBrush}"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,24,0,22">
                        <StackPanel>
                            <TextBlock Text="{Binding AvailableReleaseName}"
                                       Foreground="{StaticResource StrongTextBrush}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="A compatible Nura Windows release is ready to download and install. The desktop will restart when installation begins."
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       FontSize="13"
                                       Margin="0,10,0,0"
                                       TextWrapping="Wrap" />
                            <CheckBox x:Name="SkipVersionCheckBox"
                                      Content="Skip this version"
                                      Foreground="White"
                                      Margin="0,16,0,0"
                                      Style="{StaticResource UpdateSkipVersionCheckBoxStyle}" />
                            <StackPanel Margin="0,16,0,0"
                                        Visibility="{Binding IsUpdateBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ProgressBar Minimum="0" Maximum="100"
                                             Value="{Binding UpdateProgressPercent}"
                                             Height="7" />
                                <TextBlock Text="{Binding UpdateProgressText}"
                                           Foreground="{StaticResource SubtleTextBrush}"
                                           FontSize="12"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                            <TextBlock Text="{Binding UpdateErrorText}"
                                       Foreground="#FFFF9EA8"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,14,0,0"
                                       Visibility="{Binding HasUpdateError, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource UpdateSecondaryButtonStyle}"
                                Click="ViewReleaseButton_OnClick"
                                IsEnabled="{Binding CanViewRelease}"
                                Margin="0,0,10,0">
                            <TextBlock Text="View release" Foreground="White" FontSize="13" FontWeight="SemiBold" />
                        </Button>
                        <Button Style="{StaticResource UpdateLaterButtonStyle}"
                                Click="LaterButton_OnClick"
                                Margin="0,0,10,0">
                            <TextBlock Text="Later" Foreground="White" FontSize="13" FontWeight="SemiBold" />
                        </Button>
                        <Button Style="{StaticResource UpdatePrimaryButtonStyle}"
                                Click="UpdateNowButton_OnClick"
                                IsEnabled="{Binding CanUpdateNow}">
                            <TextBlock Text="Update now" Foreground="White" FontSize="13" FontWeight="SemiBold" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
