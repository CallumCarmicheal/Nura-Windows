<UserControl x:Class="NuraPopupWpf.Controls.CompactDevicePageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:NuraPopupWpf.Controls"
             xmlns:models="clr-namespace:NuraPopupWpf.Models"
             mc:Ignorable="d">
    <StackPanel>
        <Border Style="{StaticResource CardBorderStyle}" MinHeight="560">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <!--<TextBlock Text="{Binding CurrentDevice.Name}"
                               Foreground="White"
                               FontSize="14"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />-->

                    <Grid Grid.Column="1"
                          HorizontalAlignment="Stretch">
                        <ToggleButton x:Name="ProfileSelectorButton"
                                      Background="#10FFFFFF"
                                      BorderBrush="#22FFFFFF"
                                      BorderThickness="1"
                                      Padding="0">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="Chrome"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        MinWidth="128"
                                                        Margin="0,0"
                                                        CornerRadius="18">
                                                    <Grid Margin="12,9">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Width="18"
                                                                    Height="18"
                                                                    CornerRadius="9"
                                                                    Background="#18FF57B9">
                                                                <Image Source="{Binding CurrentProfile.Thumbnail}" Width="16" Height="16" Stretch="Fill" />
                                                            </Border>
                                                            <TextBlock Text="{Binding CurrentProfile.Name}"
                                                                       Margin="8,0,0,0"
                                                                       Foreground="White"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1"
                                                                   FontFamily="Segoe Fluent Icons"
                                                                   Text="&#xE70D;"
                                                                   Foreground="{StaticResource SubtleTextBrush}"
                                                                   FontSize="11"
                                                                   VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#16FFFFFF" />
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="Background" Value="#18FFFFFF" />
                                        </Trigger>
                                        <DataTrigger Binding="{Binding CurrentProfileCount}" Value="1">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>
                        <Popup x:Name="ProfileSelectorPopup"
                               IsOpen="{Binding IsChecked, ElementName=ProfileSelectorButton, Mode=TwoWay}"
                               AllowsTransparency="True"
                               Placement="Bottom"
                               PlacementTarget="{Binding ElementName=ProfileSelectorButton}"
                               VerticalOffset="8"
                               PopupAnimation="Fade"
                               StaysOpen="False"
                               DataContext="{Binding DataContext, ElementName=ProfileSelectorButton}">
                            <Border Width="{Binding ActualWidth, ElementName=ProfileSelectorButton}"
                                    Background="#F2121212"
                                    BorderBrush="#22FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="20"
                                    Padding="6">
                                <ListBox ItemsSource="{Binding CurrentProfiles}"
                                         SelectedItem="{Binding CurrentProfile, Mode=TwoWay}"
                                         SelectionChanged="ProfileSelectorListBox_OnSelectionChanged"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         ItemContainerStyle="{StaticResource PopupProfileItemStyle}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="18"
                                                        Height="18"
                                                        CornerRadius="9"
                                                        Background="#18FF57B9">
                                                    <Image Source="{Binding Thumbnail}" Width="16" Height="16" Stretch="Fill" />
                                                </Border>
                                                <TextBlock Text="{Binding Name}" Margin="8,0,0,0" Foreground="White" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Popup>
                    </Grid>
                    <!--<Border Grid.Column="2"
                            Background="#10FFFFFF"
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="12,8"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔋" FontSize="12" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding CurrentBatteryText}" Foreground="White" FontSize="12" />
                        </StackPanel>
                    </Border>-->
                </Grid>

                <Grid Grid.Row="1" Margin="0,18,0,18">
                    <Grid x:Name="CompactHazeHost" Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}">
                        <Ellipse HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch"
                                 RenderTransformOrigin="0.5,0.5"
                                 Visibility="{Binding ShowProfileBackgroundHaze, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Ellipse.Fill>
                                <RadialGradientBrush RadiusX="0.5" RadiusY="0.5" Center="0.5,0.5" GradientOrigin="0.5,0.5">
                                    <GradientStop Color="#4ED946EF" Offset="0.0" />
                                    <GradientStop Color="#32D946EF" Offset="0.18" />
                                    <GradientStop Color="#18D946EF" Offset="0.36" />
                                    <GradientStop Color="#06D946EF" Offset="0.60" />
                                    <GradientStop Color="#00D946EF" Offset="0.78" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.Effect>
                                <BlurEffect Radius="108" RenderingBias="Quality" />
                            </Ellipse.Effect>
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="2.5" ScaleY="2" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Grid>
                    <Ellipse Width="270"
                             Height="270"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
                        <Ellipse.Fill>
                            <RadialGradientBrush Center="0.5,0.5"
                                                 GradientOrigin="0.5,0.5"
                                                 RadiusX="0.5"
                                                 RadiusY="0.5">
                                <GradientStop Color="#14FF57B9" Offset="0" />
                                <GradientStop Color="#10FF57B9" Offset="0.42" />
                                <GradientStop Color="#08FF57B9" Offset="0.66" />
                                <GradientStop Color="#02FF57B9" Offset="0.86" />
                                <GradientStop Color="#00FF57B9" Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Ellipse Width="236" Height="236" Stroke="#18FFFFFF" StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Ellipse Width="192" Height="192" Stroke="#12FFFFFF" StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Grid Width="226"
                          Height="226"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                        
                        
                        <local:ProfileVisualControl FromProfile="{Binding VisualFromProfile}"
                                                    ToProfile="{Binding VisualToProfile}"
                                                    ProfileBlendProgress="{Binding VisualProfileBlendProgress}"
                                                    ModeProgress="{Binding VisualModeProgress}"
                                                    ImmersionValue="{Binding CurrentImmersionValue}"
                                                    IsMorphing="{Binding IsProfileMorphing}"
                                                    UseBitmapRenderer="{Binding UseBitmapProfileRenderer}" />

                        <local:ProfileVisualControl IsHitTestVisible="False"
                                                    Opacity="0.26"
                                                    FromProfile="{Binding VisualFromProfile}"
                                                    ToProfile="{Binding VisualToProfile}"
                                                    ProfileBlendProgress="{Binding VisualProfileBlendProgress}"
                                                    ModeProgress="{Binding VisualModeProgress}"
                                                    ImmersionValue="{Binding CurrentImmersionValue}"
                                                    IsMorphing="{Binding IsProfileMorphing}"
                                                    RenderShadow="False"
                                                    UseBitmapRenderer="False"
                                                    RenderTransformOrigin="0.5,0.5">
                            <local:ProfileVisualControl.CacheMode>
                                <BitmapCache RenderAtScale="0.8" />
                            </local:ProfileVisualControl.CacheMode>

                            <local:ProfileVisualControl.Style>
                                <Style TargetType="{x:Type local:ProfileVisualControl}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UseBitmapProfileRenderer}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsProfileMorphing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </local:ProfileVisualControl.Style>

                            <local:ProfileVisualControl.Effect>
                                <BlurEffect Radius="8" RenderingBias="Performance" />
                            </local:ProfileVisualControl.Effect>

                            <local:ProfileVisualControl.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="1.01" ScaleY="1.01" />
                                </TransformGroup>
                            </local:ProfileVisualControl.RenderTransform>
                        </local:ProfileVisualControl>

                    </Grid>
                </Grid>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="MODE" Style="{StaticResource SectionTitleStyle}" HorizontalAlignment="Center" />
                    <local:ModeSwitchControl Margin="0,8,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" />

                    <StackPanel Margin="8,20,8,0">
                        <TextBlock Text="Immersion mode" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                        <Slider Margin="0,12,0,0"
                            Style="{StaticResource ImmersionSliderStyle}"
                            Minimum="0"
                            Maximum="6"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            Value="{Binding ImmersionIndex, Mode=TwoWay}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}" Margin="0,16,0,16">
            <StackPanel>
                <TextBlock Text="DEVICES" Style="{StaticResource SectionTitleStyle}" />
                <ListBox x:Name="DeviceListBox"
                         Margin="0,12,0,0"
                         ItemsSource="{Binding VisibleDevices}"
                         SelectedItem="{Binding CurrentDevice, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent"
                         ItemContainerStyle="{StaticResource DeviceRailListBoxItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:DeviceModel}">
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Opacity" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                                <Setter Property="Opacity" Value="0.54" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="10" Height="10" Margin="0,2,10,0" VerticalAlignment="Top">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#55FFFFFF" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                    <Setter Property="Fill" Value="#FF64FFB0" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="White"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding DeviceStatusSummary, Mode=OneWay}"
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               FontSize="12"
                                               Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding WarningText}"
                                               Foreground="#FFFFB25F"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Margin="0,4,0,0"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasWarningText}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <ToggleButton x:Name="MoreDevicesButton"
                              Margin="0,10,0,0"
                              Background="#10FFFFFF"
                              BorderBrush="#22FFFFFF"
                              BorderThickness="1"
                              Foreground="White"
                              Height="32"
                              HorizontalAlignment="Stretch"
                              Visibility="{Binding HasOverflowDevices, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="Chrome"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="16">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Chrome" Property="Background" Value="#16FFFFFF" />
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Chrome" Property="Background" Value="#18FFFFFF" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding MoreDevicesButtonText}" />
                        <TextBlock FontFamily="Segoe Fluent Icons"
                                   Text="&#xE70D;"
                                   Margin="8,2,0,0"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource SubtleTextBrush}" />
                    </StackPanel>
                </ToggleButton>
                <Popup x:Name="MoreDevicesPopup"
                       IsOpen="{Binding IsChecked, ElementName=MoreDevicesButton}"
                       Closed="MoreDevicesPopup_OnClosed"
                       AllowsTransparency="True"
                       Placement="Bottom"
                       PlacementTarget="{Binding ElementName=MoreDevicesButton}"
                       VerticalOffset="8"
                       PopupAnimation="Fade"
                       StaysOpen="False">
                    <Border Width="{Binding ActualWidth, ElementName=MoreDevicesButton}"
                            Background="#F2121212"
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1"
                            CornerRadius="20"
                            Padding="6">
                        <ListBox ItemsSource="{Binding OverflowDevices}"
                                 SelectedItem="{Binding CurrentDevice, Mode=TwoWay}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ItemContainerStyle="{StaticResource DeviceRailListBoxItemStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:DeviceModel}">
                                    <Grid>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Opacity" Value="1" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                                        <Setter Property="Opacity" Value="0.54" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Width="10" Height="10" Margin="0,2,10,0" VerticalAlignment="Top">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#55FFFFFF" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                            <Setter Property="Fill" Value="#FF64FFB0" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="White"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding DeviceStatusSummary, Mode=OneWay}"
                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                       FontSize="12"
                                                       Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding WarningText}"
                                                       Foreground="#FFFFB25F"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Margin="0,4,0,0"
                                                       TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasWarningText}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Popup>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="CONTROLS" Style="{StaticResource SectionTitleStyle}" />
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Social mode" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                                <TextBlock Text="{Binding CurrentDevice.SocialModeText}" Foreground="White" FontSize="13" />
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          IsChecked="{Binding CurrentDevice.SocialMode, Mode=TwoWay}"
                                          Style="{StaticResource SwitchToggleButtonStyle}" />
                        </Grid>
                    </Border>
                    <Border Grid.Row="1" Style="{StaticResource InfoChipBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="ANC" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                                <TextBlock Text="{Binding CurrentDevice.AncStatusText}" Foreground="White" FontSize="13" />
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          IsChecked="{Binding CurrentDevice.AncEnabled, Mode=TwoWay}"
                                          Style="{StaticResource SwitchToggleButtonStyle}" />
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Text="DEVICE INFO" Style="{StaticResource SectionTitleStyle}" />
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,12,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Serial number" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Command="{Binding ToggleSerialVisibilityCommand}"
                                Style="{StaticResource ValuePillButtonStyle}"
                                HorizontalAlignment="Right"
                                Padding="12,6">
                            <TextBlock Margin="16,8" Text="{Binding DisplaySerial}" Foreground="White" FontFamily="Consolas" FontSize="12" />
                        </Button>
                    </Grid>
                </Border>
                <Border Style="{StaticResource InfoChipBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Software version" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding CurrentSoftwareVersion}" Foreground="White" FontSize="13" HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
