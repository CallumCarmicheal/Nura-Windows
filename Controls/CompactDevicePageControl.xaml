<UserControl x:Class="NuraPopupWpf.Controls.CompactDevicePageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:NuraPopupWpf.Controls"
             xmlns:models="clr-namespace:NuraPopupWpf.Models"
             mc:Ignorable="d">
    <StackPanel>
        <Border Style="{StaticResource CardBorderStyle}" MinHeight="560">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <!--<TextBlock Text="{Binding CurrentDevice.Name}"
                               Foreground="White"
                               FontSize="14"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />-->
                    
                    <Grid Grid.Column="1"
                          HorizontalAlignment="Stretch">
                        <ToggleButton x:Name="ProfileSelectorButton"
                                      IsChecked="{Binding IsCompactProfileSelectorOpen, Mode=TwoWay}"
                                      Background="#10FFFFFF"
                                      BorderBrush="#22FFFFFF"
                                      BorderThickness="1"
                                      Padding="0">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="Chrome"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        MinWidth="128"
                                                        Margin="0,0"
                                                        CornerRadius="18">
                                                    <Grid Margin="12,9">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Width="18"
                                                                    Height="18"
                                                                    CornerRadius="9"
                                                                    Background="#18FF57B9">
                                                                <Image Source="{Binding CurrentProfile.Thumbnail}" Width="16" Height="16" Stretch="Fill" />
                                                            </Border>
                                                            <TextBlock Text="{Binding CurrentProfile.Name}"
                                                                       Margin="8,0,0,0"
                                                                       Foreground="White"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1"
                                                                   FontFamily="Segoe Fluent Icons"
                                                                   Text="&#xE70D;"
                                                                   Foreground="{StaticResource SubtleTextBrush}"
                                                                   FontSize="11"
                                                                   VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#16FFFFFF" />
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="Background" Value="#18FFFFFF" />
                                        </Trigger>
                                        <DataTrigger Binding="{Binding CurrentProfileCount}" Value="1">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>
                        <Popup IsOpen="{Binding IsCompactProfileSelectorOpen, Mode=TwoWay}"
                               AllowsTransparency="True"
                               Placement="Bottom"
                               PlacementTarget="{Binding ElementName=ProfileSelectorButton}"
                               VerticalOffset="8"
                               PopupAnimation="Fade"
                               StaysOpen="False"
                               DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <Border Width="{Binding ActualWidth, ElementName=ProfileSelectorButton}"
                                    Background="#F2121212"
                                    BorderBrush="#22FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="20"
                                    Padding="6">
                                <ListBox ItemsSource="{Binding CurrentProfiles}"
                                         SelectedItem="{Binding CurrentProfile, Mode=TwoWay}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         ItemContainerStyle="{StaticResource PopupProfileItemStyle}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="18"
                                                        Height="18"
                                                        CornerRadius="9"
                                                        Background="#18FF57B9">
                                                    <Image Source="{Binding Thumbnail}" Width="16" Height="16" Stretch="Fill" />
                                                </Border>
                                                <TextBlock Text="{Binding Name}" Margin="8,0,0,0" Foreground="White" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Popup>
                    </Grid>
                    <!--<Border Grid.Column="2"
                            Background="#10FFFFFF"
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="12,8"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔋" FontSize="12" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding CurrentBatteryText}" Foreground="White" FontSize="12" />
                        </StackPanel>
                    </Border>-->
                </Grid>

                <Grid Grid.Row="1" Margin="0,18,0,18">
                    <Border Width="270" Height="270" CornerRadius="135" Background="#08FF57B9" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Ellipse Width="236" Height="236" Stroke="#18FFFFFF" StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Ellipse Width="192" Height="192" Stroke="#12FFFFFF" StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Grid Width="226"
                          Height="226"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                        
                        
                        <local:ProfileVisualControl FromProfile="{Binding VisualFromProfile}"
                                                    ToProfile="{Binding VisualToProfile}"
                                                    ProfileBlendProgress="{Binding VisualProfileBlendProgress}"
                                                    ModeProgress="{Binding VisualModeProgress}"
                                                    ImmersionValue="{Binding CurrentImmersionValue}"
                                                    IsMorphing="{Binding IsProfileMorphing}"
                                                    UseBitmapRenderer="{Binding UseBitmapProfileRenderer}" />

                        <local:ProfileVisualControl IsHitTestVisible="False"
                                                    Opacity="0.26"
                                                    FromProfile="{Binding VisualFromProfile}"
                                                    ToProfile="{Binding VisualToProfile}"
                                                    ProfileBlendProgress="{Binding VisualProfileBlendProgress}"
                                                    ModeProgress="{Binding VisualModeProgress}"
                                                    ImmersionValue="{Binding CurrentImmersionValue}"
                                                    IsMorphing="{Binding IsProfileMorphing}"
                                                    RenderShadow="False"
                                                    UseBitmapRenderer="False"
                                                    RenderTransformOrigin="0.5,0.5">
                            <local:ProfileVisualControl.CacheMode>
                                <BitmapCache RenderAtScale="0.8" />
                            </local:ProfileVisualControl.CacheMode>

                            <local:ProfileVisualControl.Style>
                                <Style TargetType="{x:Type local:ProfileVisualControl}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UseBitmapProfileRenderer}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsProfileMorphing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </local:ProfileVisualControl.Style>

                            <local:ProfileVisualControl.Effect>
                                <BlurEffect Radius="8" RenderingBias="Performance" />
                            </local:ProfileVisualControl.Effect>

                            <local:ProfileVisualControl.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="1.01" ScaleY="1.01" />
                                </TransformGroup>
                            </local:ProfileVisualControl.RenderTransform>
                        </local:ProfileVisualControl>

                    </Grid>
                </Grid>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="MODE" Style="{StaticResource SectionTitleStyle}" HorizontalAlignment="Center" />
                    <local:ModeSwitchControl Margin="0,8,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" />

                    <StackPanel Margin="8,20,8,0">
                        <TextBlock Text="Immersion mode" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                        <Slider Margin="0,12,0,0"
                            Style="{StaticResource ImmersionSliderStyle}"
                            Minimum="0"
                            Maximum="6"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            Value="{Binding ImmersionIndex, Mode=TwoWay}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}" Margin="0,16,0,16">
            <StackPanel>
                <TextBlock Text="DEVICES" Style="{StaticResource SectionTitleStyle}" />
                <ListBox Margin="0,12,0,0"
                         ItemsSource="{Binding Devices}"
                         SelectedItem="{Binding CurrentDevice, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         ItemContainerStyle="{StaticResource PillListBoxItemStyle}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:DeviceModel}">
                            <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="CONTROLS" Style="{StaticResource SectionTitleStyle}" />
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Social mode" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                                <TextBlock Text="{Binding SocialModeText}" Foreground="White" FontSize="13" />
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          IsChecked="{Binding SocialMode, Mode=TwoWay}"
                                          Style="{StaticResource SwitchToggleButtonStyle}" />
                        </Grid>
                    </Border>
                    <Border Grid.Row="1" Style="{StaticResource InfoChipBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="ANC" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                                <TextBlock Text="{Binding AncStatusText}" Foreground="White" FontSize="13" />
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          IsChecked="{Binding AncEnabled, Mode=TwoWay}"
                                          Style="{StaticResource SwitchToggleButtonStyle}" />
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Text="DEVICE INFO" Style="{StaticResource SectionTitleStyle}" />
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,12,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Serial number" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Command="{Binding ToggleSerialVisibilityCommand}"
                                Style="{StaticResource ValuePillButtonStyle}"
                                HorizontalAlignment="Right"
                                Padding="12,6">
                            <TextBlock Margin="16,8" Text="{Binding DisplaySerial}" Foreground="White" FontFamily="Consolas" FontSize="12" />
                        </Button>
                    </Grid>
                </Border>
                <Border Style="{StaticResource InfoChipBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Software version" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding CurrentSoftwareVersion}" Foreground="White" FontSize="13" HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
