<UserControl x:Class="NuraPopupWpf.Controls.ModeSwitchControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:Width="320"
             d:Height="48">
    <Border x:Name="RootBorder"
            Background="#10FFFFFF"
            BorderBrush="#22FFFFFF"
            BorderThickness="1"
            CornerRadius="22"
            Padding="4"
            Height="48"
            HorizontalAlignment="Stretch">
        <Grid x:Name="LayoutRoot">
            <Border x:Name="SlidingPill"
                    Width="150"
                    HorizontalAlignment="Left"
                    CornerRadius="18"
                    Opacity="0.96"
                    d:Background="#7273A1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop x:Name="PillStop1" Color="#FF8A64FF" Offset="0" />
                        <GradientStop x:Name="PillStop2" Color="#FFE14FE2" Offset="0.55" />
                        <GradientStop x:Name="PillStop3" Color="#FFFF5AB2" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <Border.RenderTransform>
                    <TranslateTransform x:Name="PillTransform" X="0" />
                </Border.RenderTransform>
            </Border>

            <UniformGrid Columns="2">
                <Button Command="{Binding SelectModeCommand}"
                        CommandParameter="Neutral"
                        Style="{StaticResource ModeSwitchButtonStyle}">
                    <TextBlock Text="Neutral"
                           HorizontalAlignment="Center"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="White" />
                </Button>
                <Button Command="{Binding SelectModeCommand}"
                        CommandParameter="Personalised"
                        Style="{StaticResource ModeSwitchButtonStyle}">
                    <TextBlock Text="Personalised"
                           HorizontalAlignment="Center"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="White" />
                </Button>
            </UniformGrid>
        </Grid>
    </Border>
</UserControl>
