<UserControl x:Class="NuraPopupWpf.Controls.CompactSettingsPageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:NuraPopupWpf.Models"
             mc:Ignorable="d">
    <StackPanel>
        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="YOUR ACCOUNT" Style="{StaticResource SectionTitleStyle}" />
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,12,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Name" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                        <TextBlock Grid.Column="1" Text="Callum" Foreground="White" HorizontalAlignment="Right" />
                    </Grid>
                </Border>
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Email address" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                        <TextBlock Grid.Column="1" Text="callum@example.com" Foreground="White" HorizontalAlignment="Right" />
                    </Grid>
                </Border>
                <Border Style="{StaticResource InfoChipBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Desktop app version" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                        <TextBlock Grid.Column="1" Text="0.1.0-alpha" Foreground="White" HorizontalAlignment="Right" />
                    </Grid>
                </Border>

                <TextBlock Text="APP" Style="{StaticResource SectionTitleStyle}" Margin="0,16,0,0" />
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Use bitmap renderer" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                            <TextBlock Text="{Binding ProfileRendererSubtitle}" Foreground="White" FontSize="13" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleButton Grid.Column="1"
                                      IsChecked="{Binding UseBitmapProfileRenderer, Mode=TwoWay}"
                                      Style="{StaticResource SwitchToggleButtonStyle}" />
                    </Grid>
                </Border>
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,10,0,0">
                    <StackPanel>
                        <Button Command="{Binding ExportHearingProfilesCommand}"
                                Style="{StaticResource ValuePillButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Padding="12,10">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock FontFamily="Segoe Fluent Icons"
                                           Text="&#xEDE1;"
                                           Foreground="White"
                                           FontSize="14"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="Export Hearing Profiles"
                                           Foreground="White"
                                           FontSize="13"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                        <TextBlock Text="{Binding ExportStatusText}"
                                   Margin="0,10,0,0"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="#22FFFFFF" Width="4" Margin="0,8" CornerRadius="4"></Border>

                    <Border Grid.Column="1" Style="{StaticResource InfoChipBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="92" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Render size" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                                <TextBlock Text="PNG size in pixels. Min 4, max 12288." Foreground="White" FontSize="13" TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Background="#10FFFFFF"
                                    BorderBrush="#22FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="24"
                                    SnapsToDevicePixels="True"
                                    Margin="20,0,0,0">
                                <TextBox Text="{Binding ExportRenderSizeText, UpdateSourceTrigger=PropertyChanged}" d:Text="12288"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="White"
                                         Padding="16,8"
                                         TextAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         PreviewTextInput="NumberOnly_PreviewTextInput"
                                         DataObject.Pasting="NumberOnly_Pasting" />
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Text="SETTINGS" Style="{StaticResource SectionTitleStyle}" />
                <ListBox Margin="0,12,0,16"
                         ItemsSource="{Binding Devices}"
                         SelectedItem="{Binding CurrentDevice, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         ItemContainerStyle="{StaticResource PillListBoxItemStyle}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:DeviceModel}">
                            <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="ANC" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                            <TextBlock Text="{Binding AncStatusText}" Foreground="White" FontSize="13" d:Text="..." />
                        </StackPanel>
                        <ToggleButton Grid.Column="1"
                                      IsChecked="{Binding AncEnabled, Mode=TwoWay}"
                                      Style="{StaticResource SwitchToggleButtonStyle}" />
                    </Grid>
                </Border>
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Enable EU volume limiter" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                            <TextBlock Text="Protect output levels" Foreground="White" FontSize="13" />
                        </StackPanel>
                        <ToggleButton Grid.Column="1"
                                      IsChecked="{Binding EuVolumeLimiter, Mode=TwoWay}"
                                      Style="{StaticResource SwitchToggleButtonStyle}" />
                    </Grid>
                </Border>
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Serial number" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Command="{Binding ToggleSerialVisibilityCommand}"
                                Style="{StaticResource ValuePillButtonStyle}"
                                HorizontalAlignment="Right"
                                Padding="12,6">
                            <TextBlock Margin="16,8" Text="{Binding DisplaySerial}" Foreground="White" FontFamily="Consolas" FontSize="12" d:Text="..." />
                        </Button>
                    </Grid>
                </Border>
                <Border Style="{StaticResource InfoChipBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Software version" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding CurrentSoftwareVersion}" Foreground="White" FontSize="13" HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
