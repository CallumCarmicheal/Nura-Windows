<UserControl x:Class="NuraPopupWpf.Controls.AuthenticationPageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:NuraPopupWpf.Controls"
             mc:Ignorable="d"
             d:Width="720"
             d:Height="720">
    <UserControl.Resources>
        <LinearGradientBrush x:Key="AuthenticationOrbBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF9A6EFF" Offset="0" />
            <GradientStop Color="#FFFF5CC7" Offset="0.52" />
            <GradientStop Color="#FFFF8C8A" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="AuthenticationPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ValuePillButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentGradientBrush}" />
            <Setter Property="BorderBrush" Value="#00FFFFFF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Height" Value="52" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.94" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.88" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AuthenticationSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ValuePillButtonStyle}">
            <Setter Property="Background" Value="#12FFFFFF" />
            <Setter Property="BorderBrush" Value="#24FFFFFF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Height" Value="48" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="AuthenticationTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#12FFFFFF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#24FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Padding" Value="18,14" />
            <Setter Property="CaretBrush" Value="#FFFF73B9" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#88FF73B9" />
                                <Setter TargetName="Chrome" Property="Background" Value="#18FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#16FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Width="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ViewportWidth}"
          Margin="0,18,0,10"
          ClipToBounds="False">
        <Ellipse Width="260"
                 Height="260"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-12,-28,0,0"
                 IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                    <GradientStop Color="#24FF70C0" Offset="0" />
                    <GradientStop Color="#10FF70C0" Offset="0.55" />
                    <GradientStop Color="#00FF70C0" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Ellipse Width="320"
                 Height="320"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-26,-42"
                 IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                    <GradientStop Color="#18A875FF" Offset="0" />
                    <GradientStop Color="#08A875FF" Offset="0.6" />
                    <GradientStop Color="#00A875FF" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Border MinHeight="640"
                MaxWidth="640"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Margin="18,0"
                Padding="28"
                Background="#F0161618"
                BorderBrush="#22FFFFFF"
                BorderThickness="1"
                CornerRadius="34">
            <Grid>
                <Grid x:Name="EmailStepPanel"
                      Opacity="1"
                      Visibility="Visible">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="EmailStepTransform" Y="0" />
                    </Grid.RenderTransform>

                    <StackPanel>
                        <Border Width="84"
                                Height="84"
                                Margin="0,2,0,18"
                                CornerRadius="42"
                                HorizontalAlignment="Left"
                                Background="#12FFFFFF"
                                BorderBrush="#26FFFFFF"
                                BorderThickness="1">
                            <Grid>
                                <Ellipse Width="46" Height="46" Fill="{StaticResource AuthenticationOrbBrush}" Opacity="0.92" />
                                <TextBlock Text="&#xE715;"
                                           FontFamily="Segoe Fluent Icons"
                                           Foreground="White"
                                           FontSize="28"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <TextBlock Text="Sign in to Nura"
                                   FontSize="34"
                                   FontWeight="SemiBold"
                                   Foreground="White" />
                        <TextBlock Margin="0,12,0,0"
                                   Text="Use your email to unlock device services, or continue offline if the headphone keys are already stored on this machine."
                                   Foreground="#B5FFFFFF"
                                   FontSize="15"
                                   LineHeight="22"
                                   TextWrapping="Wrap" />

                        <Border Margin="0,30,0,0"
                                Padding="18"
                                Background="#10FFFFFF"
                                BorderBrush="#20FFFFFF"
                                BorderThickness="1"
                                CornerRadius="24">
                            <StackPanel>
                                <TextBlock Text="Email address"
                                           Foreground="{StaticResource SubtleTextBrush}"
                                           FontSize="13" />
                                <TextBox x:Name="EmailTextBox"
                                         Margin="0,10,0,0"
                                         Style="{StaticResource AuthenticationTextBoxStyle}"
                                         Text="{Binding AuthenticationEmail, UpdateSourceTrigger=PropertyChanged}"
                                         KeyDown="EmailTextBox_OnKeyDown" />
                            </StackPanel>
                        </Border>

                        <TextBlock Margin="0,16,0,0"
                                   Text="{Binding AuthenticationStatusText}"
                                   Foreground="#CBFFFFFF"
                                   FontSize="13"
                                   LineHeight="20"
                                   TextWrapping="Wrap" />

                        <Button Margin="0,30,0,0"
                                Command="{Binding SubmitAuthenticationEmailCommand}"
                                Style="{StaticResource AuthenticationPrimaryButtonStyle}">
                            Continue
                        </Button>
                        <Button Margin="0,12,0,0"
                                Command="{Binding SkipAuthenticationCommand}"
                                Style="{StaticResource AuthenticationSecondaryButtonStyle}">
                            Skip authentication and use local keys
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid x:Name="CodeStepPanel"
                      Opacity="0"
                      Visibility="Collapsed">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="CodeStepTransform" Y="18" />
                    </Grid.RenderTransform>

                    <StackPanel>
                        <Button HorizontalAlignment="Left"
                                Command="{Binding BackToAuthenticationEmailCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#C7FFFFFF"
                                Padding="0,0,0,0"
                                FontSize="13"
                                FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72B;"
                                           FontFamily="Segoe Fluent Icons"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="Change email" />
                            </StackPanel>
                        </Button>

                        <TextBlock Margin="0,18,0,0"
                                   Text="Enter your 6-digit code"
                                   FontSize="32"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,12,0,0"
                                   Text="{Binding AuthenticationStatusText}"
                                   Foreground="#B5FFFFFF"
                                   FontSize="15"
                                   LineHeight="22"
                                   TextWrapping="Wrap" />

                        <Border Margin="0,30,0,0"
                                Padding="22"
                                Background="#12FFFFFF"
                                BorderBrush="#24FFFFFF"
                                BorderThickness="1"
                                CornerRadius="26">
                            <StackPanel>
                                <controls:OtpCodeInputControl x:Name="OtpCodeInput"
                                                              Code="{Binding AuthenticationCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              HorizontalAlignment="Stretch"
                                                                  CodeCompleted="OtpCodeInput_OnCodeCompleted" />
                                <TextBlock Margin="0,14,0,0"
                                           Text="Paste works with NNN NNN or NNNNNN."
                                           Foreground="{StaticResource SubtleTextBrush}"
                                           FontSize="12"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <Button Margin="0,28,0,0"
                                Command="{Binding VerifyAuthenticationCodeCommand}"
                                Style="{StaticResource AuthenticationPrimaryButtonStyle}">
                            Verify and continue
                        </Button>
                        <Button Margin="0,12,0,0"
                                Command="{Binding SkipAuthenticationCommand}"
                                Style="{StaticResource AuthenticationSecondaryButtonStyle}">
                            Skip authentication and use local keys
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
