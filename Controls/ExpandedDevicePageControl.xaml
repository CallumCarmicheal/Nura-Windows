<UserControl x:Class="NuraPopupWpf.Controls.ExpandedDevicePageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:NuraPopupWpf.Models"
             xmlns:local="clr-namespace:NuraPopupWpf.Controls"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" MinHeight="620" Margin="0,0,16,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--<TextBlock Text="{Binding CurrentDevice.Name}"
                               Foreground="White"
                               FontSize="14"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />-->

                    <!--<local:ExpandedProfileSelectorControl Grid.Column="1"
                                                          HorizontalAlignment="Stretch"
                                                          MinWidth="220"
                                                          MaxWidth="420"
                                                          Profiles="{Binding CurrentProfiles}"
                                                          SelectedProfile="{Binding CurrentProfile, Mode=TwoWay}" />-->

                    <!--<Border Grid.Column="2"
                            Background="#10FFFFFF"
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="12,8"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔋" FontSize="12" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding CurrentBatteryText}" Foreground="White" FontSize="12" />
                        </StackPanel>
                    </Border>-->
                </Grid>

                <Grid Grid.Row="1" Margin="0,0,0,18">
                    <Grid x:Name="HazeHost" Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}">
                        <Ellipse HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch"
                                 RenderTransformOrigin="0.5,0.5"
                                 Visibility="{Binding ShowProfileBackgroundHaze, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Ellipse.Fill>
                                <RadialGradientBrush RadiusX="0.5" RadiusY="0.5" Center="0.5,0.5" GradientOrigin="0.5,0.5">
                                    <GradientStop Color="#62D946EF" Offset="0.0" />
                                    <GradientStop Color="#42D946EF" Offset="0.20" />
                                    <GradientStop Color="#1ED946EF" Offset="0.40" />
                                    <GradientStop Color="#08D946EF" Offset="0.64" />
                                    <GradientStop Color="#00D946EF" Offset="0.82" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.Effect>
                                <BlurEffect Radius="132" RenderingBias="Quality" />
                            </Ellipse.Effect>
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="2" ScaleY="1.55" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Grid>

                    <Ellipse Width="480"
                             Height="380"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
                        <Ellipse.Fill>
                            <RadialGradientBrush Center="0.5,0.5"
                                                 GradientOrigin="0.5,0.5"
                                                 RadiusX="0.5"
                                                 RadiusY="0.5">
                                <GradientStop Color="#14FF57B9" Offset="0" />
                                <GradientStop Color="#10FF57B9" Offset="0.42" />
                                <GradientStop Color="#08FF57B9" Offset="0.66" />
                                <GradientStop Color="#02FF57B9" Offset="0.86" />
                                <GradientStop Color="#00FF57B9" Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <Grid >
                        <Ellipse Width="402" Height="402" Stroke="#18FFFFFF" StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Ellipse Width="312" Height="312" Stroke="#12FFFFFF" StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>

                    <Grid 
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Margin="18,32">
                        <Border Height="312"
                                Margin="4,0"
                                CornerRadius="110"
                                BorderBrush="#18FFFFFF"
                                BorderThickness="1"
                                Background="#00000000"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center" />
                        <Border Height="206"
                                Margin="56,0"
                                CornerRadius="78"
                                BorderBrush="#12FFFFFF"
                                BorderThickness="1"
                                Background="#00000000"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center" />
                    </Grid>

                    <Grid Width="360" Height="360" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <local:ProfileVisualControl Opacity="1" FromProfile="{Binding VisualFromProfile}"
                                                    ToProfile="{Binding VisualToProfile}"
                                                    ProfileBlendProgress="{Binding VisualProfileBlendProgress}"
                                                    ModeProgress="{Binding VisualModeProgress}"
                                                    ImmersionValue="{Binding CurrentImmersionValue}"
                                                    IsMorphing="{Binding IsProfileMorphing}"
                                                    UseBitmapRenderer="{Binding UseBitmapProfileRenderer}" />

                        <local:ProfileVisualControl IsHitTestVisible="False"
                                                    Opacity="0.28"
                                                    FromProfile="{Binding VisualFromProfile}"
                                                    ToProfile="{Binding VisualToProfile}"
                                                    ProfileBlendProgress="{Binding VisualProfileBlendProgress}"
                                                    ModeProgress="{Binding VisualModeProgress}"
                                                    ImmersionValue="{Binding CurrentImmersionValue}"
                                                    IsMorphing="{Binding IsProfileMorphing}"
                                                    RenderShadow="False"
                                                    UseBitmapRenderer="False"
                                                    RenderTransformOrigin="0.5,0.5">

                            <local:ProfileVisualControl.CacheMode>
                                <BitmapCache RenderAtScale="0.8" />
                            </local:ProfileVisualControl.CacheMode>

                            <local:ProfileVisualControl.Style>
                                <Style TargetType="{x:Type local:ProfileVisualControl}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UseBitmapProfileRenderer}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </local:ProfileVisualControl.Style>

                            <local:ProfileVisualControl.Effect>
                                <BlurEffect Radius="10" RenderingBias="Performance" />
                            </local:ProfileVisualControl.Effect>

                            <local:ProfileVisualControl.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="1.01" ScaleY="1.01" />
                                </TransformGroup>
                            </local:ProfileVisualControl.RenderTransform>
                        </local:ProfileVisualControl>

                    </Grid>
                </Grid>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="MODE" Style="{StaticResource SectionTitleStyle}" HorizontalAlignment="Center" />
                    <local:ModeSwitchControl Margin="0,8,0,0"
                                             HorizontalAlignment="Stretch" />

                    <StackPanel Margin="8,20,8,0">
                        <TextBlock Text="Immersion mode" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                        <Slider Margin="0,12,0,0"
                                Style="{StaticResource ImmersionSliderStyle}"
                                Minimum="0"
                                Maximum="6"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Value="{Binding ImmersionIndex, Mode=TwoWay}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Column="1">
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="DEVICES" Style="{StaticResource SectionTitleStyle}" />
                    <ListBox x:Name="DeviceListBox"
                             Margin="0,12,0,0"
                             ItemsSource="{Binding Devices}"
                             SelectedItem="{Binding CurrentDevice, Mode=TwoWay}"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemContainerStyle="{StaticResource DeviceRailListBoxItemStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:DeviceModel}">
                                <Grid>
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Opacity" Value="1" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                                    <Setter Property="Opacity" Value="0.54" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Width="10" Height="10" Margin="0,2,10,0" VerticalAlignment="Top">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#55FFFFFF" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                        <Setter Property="Fill" Value="#FF64FFB0" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding DeviceStatusSummary, Mode=OneWay}"
                                                   Foreground="{StaticResource SubtleTextBrush}"
                                                   FontSize="12"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="CONTROLS" Style="{StaticResource SectionTitleStyle}" />
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Social mode" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                                    <TextBlock Text="{Binding CurrentDevice.SocialModeText}" Foreground="White" FontSize="13" />
                                </StackPanel>
                                <ToggleButton Grid.Column="1"
                                              IsChecked="{Binding CurrentDevice.SocialMode, Mode=TwoWay}"
                                              Style="{StaticResource SwitchToggleButtonStyle}" />
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource InfoChipBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="ANC" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                                    <TextBlock Text="{Binding CurrentDevice.AncStatusText}" Foreground="White" FontSize="13" />
                                </StackPanel>
                                <ToggleButton Grid.Column="1"
                                              IsChecked="{Binding CurrentDevice.AncEnabled, Mode=TwoWay}"
                                              Style="{StaticResource SwitchToggleButtonStyle}" />
                            </Grid>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="DEVICE INFO" Style="{StaticResource SectionTitleStyle}" />
                    <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,12,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Serial number" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Command="{Binding ToggleSerialVisibilityCommand}"
                                    Style="{StaticResource ValuePillButtonStyle}"
                                    HorizontalAlignment="Right"
                                    Padding="12,6">
                                <TextBlock Margin="16,8" Text="{Binding DisplaySerial}" Foreground="White" FontFamily="Consolas" FontSize="12" />
                            </Button>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource InfoChipBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Software version" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding CurrentSoftwareVersion}" Foreground="White" FontSize="13" HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
